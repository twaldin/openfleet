#!/usr/bin/env node

const os = require('os')
const path = require('path')
const { parseArgs } = require('../lib/opencode')
const { renderOpsTui } = require('../core/ops-tui')

const args = parseArgs(process.argv.slice(2))
const stateRoot = args['state-root'] || process.env.OPENFLEET_CANONICAL_STATE_DIR || path.join(os.homedir(), '.openfleet')
const intervalMs = Number(args.interval || 2000)

if (args.once) {
  process.stdout.write(`${renderOpsTui(stateRoot, { width: process.stdout.columns || 100 })}\n`)
  process.exit(0)
}

render()
const timer = setInterval(render, intervalMs)

if (process.stdin.isTTY) {
  process.stdin.setRawMode(true)
  process.stdin.resume()
  process.stdin.on('data', (chunk) => {
    const key = String(chunk)
    if (key === 'q' || key === '\u0003') {
      clearInterval(timer)
      process.stdout.write('\n')
      process.exit(0)
    }
    if (key === 'r') {
      render()
    }
  })
}

function render() {
  process.stdout.write('\u001bc')
  process.stdout.write(`${renderOpsTui(stateRoot, { width: process.stdout.columns || 100 })}\n`)
}
