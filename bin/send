#!/usr/bin/env node
// Universal message sender — routes to any agent regardless of harness
const { execFileSync } = require("child_process")
const os = require("os")
const path = require("path")
const fs = require("fs")
const { parseArgs } = require("../lib/opencode")
const { loadRegistry, saveRegistry, upsertSession } = require("../core/runtime/registry")
const { loadActiveOrchestrator } = require("../core/runtime/orchestrator")
const { createEventStore } = require("../core/runtime/events")

function main() {
  const args = parseArgs(process.argv.slice(2))
  const stateRoot = args["state-root"] || process.env.OPENFLEET_CANONICAL_STATE_DIR || path.join(os.homedir(), ".openfleet")
  const direction = args.direction || "parent_to_worker"

  // Handle --to-parent mode (flag parsed by parseArgs, not positional)
  if (args["to-parent"]) {
    const message = args._.join(" ").trim() || args.message || ""
    if (!message) {
      console.error("Usage: send --to-parent --sender <name> --message \"text\"")
      process.exit(1)
    }
    return sendToParent(stateRoot, message, args.sender)
  }

  const target = args._[0]
  const message = args._.slice(1).join(" ").trim() || args.message || ""

  if (!target || !message) {
    console.error("Usage: send <agent-name> <message>")
    console.error("       send --to-parent --sender <name> --message \"text\"")
    process.exit(1)
  }

  // Look up agent in registry
  const registry = loadRegistry(stateRoot)
  const session = findAgentSession(registry, target)

  if (!session) {
    console.error(`Agent '${target}' not found in registry. Known agents:`)
    Object.values(registry.sessions).forEach(s => {
      if (s.name) console.error(`  ${s.name} (${s.harness || "unknown"})`)
    })
    process.exit(1)
  }

  const harness = session.harness || "opencode"
  const tmuxSession = session.tmux_session
  const tmuxWindow = session.tmux_window

  if (harness === "opencode") {
    // OpenCode: use opencode run --attach to send to the headless server
    const dir = (session.directory || session.workspace || path.join(stateRoot, "agents", target)).replace(/^~/, os.homedir())
    const port = session.opencode_port || (14000 + Math.abs([...target].reduce((h, c) => (h * 31 + c.charCodeAt(0)) | 0, 0) % 1000))
    sendViaOpencodeRun(dir, message, port, target)
    console.log(`Sent to ${target} via opencode run --attach :${port}`)
  } else if (tmuxSession && tmuxWindow && hasTmuxWindow(tmuxSession, tmuxWindow)) {
    // Claude Code / Codex: use tmux send-keys
    sendViaTmux(tmuxSession, tmuxWindow, message)
    console.log(`Sent to ${target} via tmux @ ${tmuxSession}:${tmuxWindow}`)
  } else {
    console.error(`Cannot route message to ${target}: no tmux coords or opencode session`)
    process.exit(1)
  }

  // Emit event
  createEventStore(stateRoot).append({
    type: "message.created",
    session_id: session.session_id,
    agent_id: target,
    payload: { direction, text: message },
  })
}

function sendToParent(stateRoot, message, sender) {
  const orchestrator = loadActiveOrchestrator(stateRoot)
  if (!orchestrator) {
    console.error("No active orchestrator registered")
    process.exit(1)
  }

  const label = sender ? `[${sender.toUpperCase()}]: ` : ""
  const fullMessage = `${label}${message}`

  if (orchestrator.harness === "opencode" && orchestrator.session_id) {
    const baseUrl = process.env.OPENCODE_URL || "http://127.0.0.1:4096"
    const url = `${baseUrl}/session/${orchestrator.session_id}/prompt_async?directory=${encodeURIComponent(orchestrator.workdir || "")}`
    const payload = JSON.stringify({ parts: [{ type: "text", text: fullMessage }] })
    execFileSync("curl", ["--max-time", "10", "-sS", "-X", "POST", "-H", "Content-Type: application/json", "-d", payload, url], { encoding: "utf8" })
  } else if (orchestrator.tmux_session && orchestrator.tmux_window) {
    sendViaTmux(orchestrator.tmux_session, orchestrator.tmux_window, fullMessage)
  } else {
    console.error("Cannot route to parent: no transport available")
    process.exit(1)
  }

  createEventStore(stateRoot).append({
    type: "message.created",
    agent_id: sender || "unknown",
    payload: { direction: "worker_to_parent", text: fullMessage },
  })

  console.log(`Sent to parent (${orchestrator.harness})`)
}

function findAgentSession(registry, name) {
  // First try by name
  for (const session of Object.values(registry.sessions)) {
    if (session.name === name || session.agent_id === name) return session
  }
  return null
}

function sendViaTmux(session, window, message) {
  const target = `${session}:${window}`
  // Use load-buffer for long messages to avoid shell escaping issues
  if (message.length > 500) {
    const tmp = path.join(os.tmpdir(), `openfleet-send-${Date.now()}.txt`)
    fs.writeFileSync(tmp, message)
    execFileSync("tmux", ["load-buffer", tmp], { stdio: "ignore" })
    execFileSync("tmux", ["paste-buffer", "-t", target], { stdio: "ignore" })
    fs.unlinkSync(tmp)
  } else {
    execFileSync("tmux", ["send-keys", "-t", target, "-l", message], { stdio: "ignore" })
  }
  // Small delay then Enter — Codex TUI sometimes needs a moment after paste
  sleep(300)
  execFileSync("tmux", ["send-keys", "-t", target, "Enter"], { stdio: "ignore" })
  // Second Enter after delay — catches Codex/Claude prompts that need confirmation
  sleep(200)
  execFileSync("tmux", ["send-keys", "-t", target, "Enter"], { stdio: "ignore" })
}

function sleep(ms) {
  Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, ms)
}

function sendViaOpencodeRun(dir, message, port, agentName) {
  // Use the TUI API to inject the message directly into the live TUI
  // append-prompt sets the text, submit-prompt sends it
  execFileSync("curl", [
    "-sS", "-X", "POST", `http://127.0.0.1:${port}/tui/append-prompt`,
    "-H", "Content-Type: application/json",
    "-d", JSON.stringify({ text: message }),
  ], { encoding: "utf8", timeout: 5000 })
  sleep(500)
  execFileSync("curl", [
    "-sS", "-X", "POST", `http://127.0.0.1:${port}/tui/submit-prompt`,
  ], { encoding: "utf8", timeout: 5000 })
}

function hasTmuxWindow(session, window) {
  try {
    execFileSync("tmux", ["has-session", "-t", session], { stdio: "ignore" })
    const wins = execFileSync("tmux", ["list-windows", "-t", session, "-F", "#{window_name}"], { encoding: "utf8" })
    return wins.split("\n").includes(window)
  } catch { return false }
}

try {
  main()
} catch (e) {
  console.error(e.message)
  process.exit(1)
}
