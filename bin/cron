#!/usr/bin/env node
// OpenFleet cron scheduler — reads schedule from ~/.openfleet/cron.json
// Source code never needs to change. Customize prompts, targets, schedules in the config.
const { execFileSync } = require("child_process")
const fs = require("fs")
const os = require("os")
const path = require("path")

const STATE_ROOT = process.env.OPENFLEET_CANONICAL_STATE_DIR || path.join(os.homedir(), ".openfleet")
const CRON_CONFIG = path.join(STATE_ROOT, "cron.json")
const CRON_STATE = path.join(STATE_ROOT, "cron-state.json")
const BIN = __dirname

function loadConfig() {
  try {
    return JSON.parse(fs.readFileSync(CRON_CONFIG, "utf8"))
  } catch {
    log(`No cron config at ${CRON_CONFIG} — nothing to schedule`)
    return { jobs: [] }
  }
}

function loadCronState() {
  try { return JSON.parse(fs.readFileSync(CRON_STATE, "utf8")) } catch { return {} }
}

function saveCronState(state) {
  fs.writeFileSync(CRON_STATE, JSON.stringify(state, null, 2))
}

function shouldFire(job, now, state) {
  if (!evaluateCondition(job.condition)) {
    return false
  }

  const lastFired = state[job.id] ? new Date(state[job.id]).getTime() : 0
  const sched = job.schedule || {}

  // Interval-based
  if (sched.intervalMinutes) {
    return (now.getTime() - lastFired) >= sched.intervalMinutes * 60 * 1000
  }

  // Time-of-day
  if (sched.hour != null) {
    const h = now.getHours()
    const m = now.getMinutes()
    if (h !== sched.hour || Math.abs(m - (sched.minute || 0)) > 2) return false
    if (sched.days && !sched.days.includes(now.getDay())) return false
    const windowStart = new Date(now)
    windowStart.setMinutes((sched.minute || 0) - 2, 0, 0)
    return lastFired < windowStart.getTime()
  }

  return false
}

function evaluateCondition(condition) {
  if (!condition) return true

  const type = typeof condition === "string" ? condition : condition.type
  throw new Error(`Unknown cron condition type: ${type || "<missing>"}`)
}

function executeJob(job, { binDir = BIN, runImpl = run } = {}) {
  const target = job.target
  const prompt = job.prompt

  if (!target || !prompt) {
    log(`Job ${job.id}: missing target or prompt, skipping`)
    return
  }

  log(`Firing: ${job.id} → ${target}`)

  if (target === "parent" || target === "orchestrator") {
    runImpl("node", [path.join(binDir, "send"), "--to-parent", "--sender", "cron", "--message", prompt])
  } else {
    runImpl("node", [path.join(binDir, "send"), target, "--sender", "cron", "--message", prompt])
  }
}

function tick() {
  const now = new Date()
  const state = loadCronState()
  const config = loadConfig()

  for (const job of config.jobs || []) {
    try {
      if (shouldFire(job, now, state)) {
        executeJob(job)
        state[job.id] = now.toISOString()
      }
    } catch (e) {
      log(`Cron ${job.id} failed: ${e.message}`)
    }
  }

  saveCronState(state)
}

function formatSchedule(sched) {
  if (!sched) return "?"
  if (sched.intervalMinutes) return `every ${sched.intervalMinutes}m`
  const h = sched.hour != null ? String(sched.hour).padStart(2, "0") : "?"
  const m = String(sched.minute || 0).padStart(2, "0")
  const days = sched.days ? " M-F" : ""
  return `${h}:${m}${days}`
}

function run(cmd, args) {
  execFileSync(cmd, args, { stdio: "pipe", encoding: "utf8", timeout: 30000 })
}

function log(msg) {
  process.stderr.write(`[cron ${new Date().toISOString().slice(11, 19)}] ${msg}\n`)
}

// --- Main ---

const args = process.argv.slice(2)

if (require.main === module) {
  if (args.includes("--list")) {
    const state = loadCronState()
    const config = loadConfig()
    for (const job of config.jobs || []) {
      const last = state[job.id] || "never"
      const sched = formatSchedule(job.schedule)
      console.log(`${job.id.padEnd(25)} ${sched.padEnd(15)} → ${(job.target || "?").padEnd(15)} last: ${last}`)
    }
    process.exit(0)
  }

  if (args.includes("--once")) {
    tick()
    process.exit(0)
  }

  log("Cron scheduler started — reading from " + CRON_CONFIG)
  tick()
  setInterval(tick, 60_000)

  process.on("SIGINT", () => process.exit(0))
  process.on("SIGTERM", () => process.exit(0))
}

module.exports = {
  evaluateCondition,
  executeJob,
  formatSchedule,
  loadConfig,
  loadCronState,
  saveCronState,
  shouldFire,
  tick,
}
