#!/usr/bin/env node
// Universal agent spawner — works for any harness, with optional git worktree isolation
const { execFileSync } = require("child_process")
const fs = require("fs")
const os = require("os")
const path = require("path")
const { parseArgs } = require("../lib/opencode")
const { loadDeploymentConfig } = require("../core/deployment")
const { projectInstructions } = require("../core/instructions")
const { loadRegistry, saveRegistry, upsertSession } = require("../core/runtime/registry")
const { createEventStore } = require("../core/runtime/events")

function main() {
  const args = parseArgs(process.argv.slice(2))
  const name = args._[0]
  const harness = args.harness || "claude-code"
  const model = args.model || "opus-4.6"
  let workdir = args.dir || process.env.OPENFLEET_WORKSPACE_ROOT || os.homedir()
  const tmuxSession = args["tmux-session"] || "openfleet"
  const stateRoot = args["state-root"] || process.env.OPENFLEET_CANONICAL_STATE_DIR || path.join(os.homedir(), ".openfleet")
  const bootstrap = args.bootstrap || null
  const useWorktree = args.worktree || false
  const baseBranch = args["base-branch"] || "main"
  const deploymentPath = process.env.OPENFLEET_DEPLOYMENT || null

  if (!name) {
    console.error("Usage: spawn <name> --harness <claude-code|codex|opencode> --model <model> [--dir <workdir>] [--worktree] [--bootstrap <prompt>]")
    process.exit(1)
  }

  // Create git worktree for isolation if requested
  let worktreeInfo = null
  if (useWorktree) {
    worktreeInfo = createWorktree(workdir, name, baseBranch)
    workdir = worktreeInfo.path
  }

  if (deploymentPath) {
    try {
      const deployment = loadDeploymentConfig(deploymentPath)
      if (deployment) {
        projectInstructions(name, name, harness, workdir, deployment)
      }
    } catch {}
  }

  // Ensure tmux session exists
  try {
    execFileSync("tmux", ["has-session", "-t", tmuxSession], { stdio: "ignore" })
  } catch {
    execFileSync("tmux", ["new-session", "-d", "-s", tmuxSession, "-n", "bootstrap"], { stdio: "ignore" })
  }

  // Kill existing window if any
  try {
    execFileSync("tmux", ["kill-window", "-t", `${tmuxSession}:${name}`], { stdio: "ignore" })
  } catch { /* fine */ }

  // Launch the right CLI
  let launchCmd
  switch (harness) {
    case "claude-code":
      launchCmd = `claude --dangerously-skip-permissions --model ${model}`
      break
    case "codex":
      launchCmd = `codex -m ${model} -C ${workdir} --full-auto`
      break
    case "opencode":
      launchCmd = `opencode`
      break
    default:
      console.error(`Unknown harness: ${harness}`)
      process.exit(1)
  }

  execFileSync("tmux", [
    "new-window", "-t", tmuxSession, "-n", name, "-c", workdir, launchCmd,
  ], { stdio: "ignore", shell: true })

  // Wait for CLI to initialize
  sleep(3000)

  // Handle Codex trust prompt
  if (harness === "codex") {
    const pane = capturePane(tmuxSession, name)
    if (pane.includes("Do you trust")) {
      execFileSync("tmux", ["send-keys", "-t", `${tmuxSession}:${name}`, "1", "Enter"], { stdio: "ignore" })
      sleep(1500)
    }
  }

  // Send bootstrap prompt if provided
  if (bootstrap) {
    if (harness === "opencode") {
      // OpenCode: use HTTP session API instead of tmux send-keys (more reliable)
      sleep(5000) // Extra wait for OpenCode TUI + server
      try {
        execFileSync("node", [
          path.join(__dirname, "message_agent"), name,
          "--agent", name,
          "--canonical-state-dir", stateRoot,
          bootstrap,
        ], { encoding: "utf8", timeout: 30000 })
      } catch (e) {
        console.error(`Warning: bootstrap via session API failed, falling back to tmux: ${e.message}`)
        sendToPane(tmuxSession, name, bootstrap)
      }
    } else {
      sendToPane(tmuxSession, name, bootstrap)
    }
  }

  // Register in openfleet registry
  const registry = loadRegistry(stateRoot)
  const sessionId = `spawn_${name}_${Date.now()}`
  upsertSession(registry, {
    session_id: sessionId,
    name,
    agent_id: name,
    runtime_instance_id: name,
    harness,
    model,
    tmux_session: tmuxSession,
    tmux_window: name,
    directory: workdir,
    agentProfile: name,
    workspace: workdir,
    worktree: worktreeInfo,
    created_at: Date.now(),
  })
  saveRegistry(stateRoot, registry)

  // Emit event
  createEventStore(stateRoot).append({
    type: "session.spawned",
    session_id: sessionId,
    agent_id: name,
    payload: {
      harness, model,
      tmux_session: tmuxSession, tmux_window: name,
      workdir,
      worktree: worktreeInfo,
    },
  })

  const result = {
    ok: true,
    name,
    harness,
    model,
    session_id: sessionId,
    tmux_session: tmuxSession,
    tmux_window: name,
    workdir,
    worktree: worktreeInfo,
  }
  console.log(JSON.stringify(result, null, 2))
}

function createWorktree(repoDir, name, baseBranch) {
  const branch = `openfleet/${name}`
  const worktreePath = path.join(os.tmpdir(), `openfleet-wt-${name}-${Date.now()}`)

  // Create branch from base
  try {
    execFileSync("git", ["-C", repoDir, "branch", "-D", branch], { stdio: "ignore" })
  } catch { /* branch didn't exist */ }

  execFileSync("git", ["-C", repoDir, "worktree", "add", "-b", branch, worktreePath, baseBranch], {
    stdio: "pipe", encoding: "utf8",
  })

  return { path: worktreePath, branch, base: baseBranch, repo: repoDir }
}

function sendToPane(session, window, message) {
  // Use load-buffer/paste-buffer for long messages, send-keys for short
  if (message.length > 500) {
    const tmp = path.join(os.tmpdir(), `openfleet-spawn-${Date.now()}.txt`)
    fs.writeFileSync(tmp, message)
    execFileSync("tmux", ["load-buffer", tmp], { stdio: "ignore" })
    execFileSync("tmux", ["paste-buffer", "-t", `${session}:${window}`], { stdio: "ignore" })
    fs.unlinkSync(tmp)
  } else {
    execFileSync("tmux", ["send-keys", "-t", `${session}:${window}`, "-l", message], { stdio: "ignore" })
  }
  execFileSync("tmux", ["send-keys", "-t", `${session}:${window}`, "Enter"], { stdio: "ignore" })
}

function capturePane(session, window) {
  return execFileSync("tmux", ["capture-pane", "-pt", `${session}:${window}`, "-S", "-40"], { encoding: "utf8" })
}

function sleep(ms) {
  Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, ms)
}

try {
  main()
} catch (e) {
  console.error(e.message)
  process.exit(1)
}
