#!/usr/bin/env node

const os = require("os")
const path = require("path")
const { parseArgs } = require("../lib/opencode")
const { resolveLatestByChannel } = require("../core/runtime/resolution")

function main() {
  const args = parseArgs(process.argv.slice(2))
  const stateRoot = args["state-root"] || process.env.OPENFLEET_CANONICAL_STATE_DIR || path.join(os.homedir(), ".openfleet")
  const channel = args.channel
  const actor = args.actor || "human"
  const message = args.message || args._.join(" ")

  if (!channel || !message) {
    throw new Error("Usage: resolve --channel <binding> --actor <id> --message <text>")
  }

  let result = null
  try {
    result = resolveLatestByChannel(stateRoot, "approval", channel, {
      resolved_by: actor,
      resolution: message,
      status: "approved",
    })
  } catch {
    result = resolveLatestByChannel(stateRoot, "blocker", channel, {
      resolved_by: actor,
      answer: message,
      status: "answered",
    })
  }

  process.stdout.write(`${JSON.stringify(result, null, 2)}\n`)
}

try {
  main()
} catch (error) {
  console.error(error.message)
  process.exit(1)
}
