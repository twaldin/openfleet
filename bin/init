#!/usr/bin/env node
const { execFileSync } = require("node:child_process")
const fs = require("node:fs")
const path = require("node:path")
const readline = require("node:readline")

const { defaultStateRoot, generateAuthToken, saveRemoteConfig } = require("../core/remote/config")
const { saveAgents } = require("../core/runtime/agents")
const { saveActiveOrchestrator } = require("../core/runtime/orchestrator")

const MODEL_CHOICES = ["claude", "gpt", "local"]
const HARNESS_CHOICES = ["claude-code", "opencode", "openclaw"]
const DEFAULT_DASHBOARD_URL = process.env.OPENFLEET_DASHBOARD_URL || "http://localhost:3000"
const DEFAULT_HEARTBEAT_CRON = {
  jobs: [
    {
      id: "heartbeat",
      description: "Hourly fleet heartbeat",
      schedule: { intervalMinutes: 60 },
      target: "parent",
      action: "message",
      prompt: "[HEARTBEAT] Check fleet health, blocked work, and new messages. Report only material changes.",
    },
  ],
}

function renderHelp() {
  return `openfleet init - interactive setup wizard

Usage:
  openfleet init

Creates ~/.openfleet with:
  - remote.json
  - agents.json
  - cron.json
  - agents/cairn/

Options:
  --help, -h    Show this help message
`
}

function createPrompter({ input = process.stdin, output = process.stdout } = {}) {
  const rl = readline.createInterface({ input, output })

  return {
    ask(message, { defaultValue = "" } = {}) {
      const suffix = defaultValue ? ` [${defaultValue}]` : ""
      return new Promise((resolve) => {
        rl.question(`${message}${suffix}: `, (answer) => {
          const trimmed = answer.trim()
          resolve(trimmed || defaultValue)
        })
      })
    },
    close() {
      rl.close()
    },
  }
}

async function askChoice(prompter, writeLine, message, choices, defaultValue) {
  while (true) {
    const answer = await prompter.ask(`${message} (${choices.join("/")})`, { defaultValue })
    const normalized = String(answer || "").trim().toLowerCase()
    const match = choices.find((choice) => choice.toLowerCase() === normalized)
    if (match) return match
    writeLine(`Choose one of: ${choices.join(", ")}`)
  }
}

function writeJson(filePath, value) {
  fs.mkdirSync(path.dirname(filePath), { recursive: true })
  fs.writeFileSync(filePath, `${JSON.stringify(value, null, 2)}\n`, "utf8")
}

function printQrIfPossible(url, { writeLine = console.log } = {}) {
  try {
    const qr = execFileSync("qrencode", ["-t", "ANSIUTF8", url], {
      encoding: "utf8",
      stdio: ["ignore", "pipe", "ignore"],
    })
    if (!qr.trim()) return false

    writeLine("Dashboard QR:")
    for (const line of qr.trimEnd().split("\n")) {
      writeLine(line)
    }
    return true
  } catch {
    return false
  }
}

async function runWizard(prompter, {
  stateRoot = defaultStateRoot(),
  writeLine = console.log,
  tokenGenerator = generateAuthToken,
  dashboardUrl = DEFAULT_DASHBOARD_URL,
  printQr = printQrIfPossible,
  now = () => new Date().toISOString(),
} = {}) {
  writeLine("Welcome to OpenFleet.")
  writeLine("OpenFleet gives you one control plane for AI CLI agents across Claude Code, OpenCode, and OpenClaw.")
  writeLine()

  const discordToken = await prompter.ask("Discord bot token (optional - press enter to skip)")
  const discordGuild = discordToken
    ? await prompter.ask("Discord guild ID")
    : ""

  const model = await askChoice(prompter, writeLine, "Default model", MODEL_CHOICES, "claude")
  const harness = await askChoice(prompter, writeLine, "Default harness", HARNESS_CHOICES, "claude-code")
  const authToken = tokenGenerator()

  const agentsRoot = path.join(stateRoot, "agents")
  const orchestratorDir = path.join(agentsRoot, "cairn")
  fs.mkdirSync(orchestratorDir, { recursive: true })

  saveRemoteConfig(stateRoot, {
    provider: discordToken ? "discord" : null,
    discord: {
      token: discordToken || null,
      guild: discordGuild || null,
    },
    defaults: {
      model,
      harness,
    },
    auth: {
      token: authToken,
    },
  })

  saveAgents(stateRoot, {})
  writeJson(path.join(stateRoot, "cron.json"), DEFAULT_HEARTBEAT_CRON)

  saveActiveOrchestrator(stateRoot, {
    name: "cairn",
    agent_id: "cairn",
    harness,
    model,
    tmux_session: "openfleet",
    tmux_window: "cairn",
    workdir: orchestratorDir,
    activated_at: now(),
  })

  if (discordToken) {
    writeJson(path.join(stateRoot, "discord.json"), {
      token: discordToken,
      guild_id: discordGuild || null,
      channels: {},
    })
  }

  writeLine()
  writeLine("Setup complete! Run openfleet start to boot the fleet.")
  writeLine(`Dashboard URL: ${dashboardUrl}`)
  writeLine(`Dashboard auth token: ${authToken}`)
  printQr(dashboardUrl, { authToken, writeLine })

  return {
    authToken,
    dashboardUrl,
    stateRoot,
  }
}

async function main(argv = process.argv.slice(2)) {
  if (argv.includes("--help") || argv.includes("-h")) {
    process.stdout.write(renderHelp())
    return
  }

  const prompter = createPrompter()
  try {
    await runWizard(prompter)
  } finally {
    prompter.close()
  }
}

if (require.main === module) {
  main().catch((error) => {
    console.error(error.message)
    process.exit(1)
  })
}

module.exports = {
  createPrompter,
  main,
  printQrIfPossible,
  renderHelp,
  runWizard,
}
