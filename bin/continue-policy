#!/usr/bin/env node

const os = require("os")
const path = require("path")
const { parseArgs } = require("../lib/opencode")
const { decideContinuation } = require("../core/continuation")

function main() {
  const args = parseArgs(process.argv.slice(2))
  const stateRoot = args["state-root"] || process.env.OPENFLEET_CANONICAL_STATE_DIR || path.join(os.homedir(), ".openfleet")
  const source = args.source || "orchestrator"
  const result = decideContinuation(stateRoot, { source })
  process.stdout.write(`${JSON.stringify(result, null, 2)}\n`)
}

try {
  main()
} catch (error) {
  console.error(error.message)
  process.exit(1)
}
