#!/usr/bin/env node
// OpenFleet Dashboard — web UI for fleet monitoring and control
const http = require("http")
const crypto = require("crypto")
const fs = require("fs")
const os = require("os")
const path = require("path")
const { execFileSync } = require("child_process")
const { parseArgs } = require("../lib/opencode")
const { ensureAuthToken } = require("../core/remote/config")
const { loadAgents } = require("../core/runtime/agents")
const { loadRegistry } = require("../core/runtime/registry")
const { loadTasks, listTasks } = require("../core/runtime/tasks")
const { loadBlockers, listBlockers } = require("../core/runtime/blockers")
const { loadApprovals, listApprovals } = require("../core/runtime/approvals")
const { readEvents } = require("../core/runtime/events")

const args = parseArgs(process.argv.slice(2))

if (args.help || args.h) {
  console.log(`openfleet dashboard — web UI for fleet monitoring

USAGE
  dashboard [--port <port>]

OPTIONS
  --port <n>    Port to listen on (default: 3000, or OPENFLEET_DASHBOARD_PORT)
  --help        Show this help

ENVIRONMENT
  OPENFLEET_DASHBOARD_PORT    Port override
  OPENFLEET_CANONICAL_STATE_DIR   State directory (default: ~/.openfleet)
`)
  process.exit(0)
}

const PORT = Number(args.port || process.env.OPENFLEET_DASHBOARD_PORT || 3000)
const STATE_ROOT = process.env.OPENFLEET_CANONICAL_STATE_DIR || path.join(os.homedir(), ".openfleet")
const BIN = __dirname
const CORE = path.join(__dirname, "..", "core")
const NODE_MODULES = path.join(__dirname, "..", "node_modules")
const START_TIME = Date.now()
const SSE_INTERVAL_MS = Number(process.env.OPENFLEET_DASHBOARD_SSE_INTERVAL_MS || 5000)

// --- Liveness check (same pattern as agent-lifecycle) ---

// Cache tmux window list (refreshed every 5s)
let tmuxWindowCache = new Set()
let tmuxCacheTime = 0
function getLiveTmuxWindows() {
  if (Date.now() - tmuxCacheTime < 5000) return tmuxWindowCache
  try {
    const out = execFileSync("tmux", ["list-windows", "-t", "openfleet", "-F", "#{window_name}"], { encoding: "utf8" })
    tmuxWindowCache = new Set(out.trim().split("\n").filter(Boolean))
  } catch { tmuxWindowCache = new Set() }
  tmuxCacheTime = Date.now()
  return tmuxWindowCache
}

function isAlive(session, name) {
  // Check explicit tmux coords
  if (session?.tmux_session && session?.tmux_window) {
    const wins = getLiveTmuxWindows()
    if (wins.has(session.tmux_window)) return true
  }
  // Fallback: check if a tmux window named after the agent exists
  if (name) {
    const wins = getLiveTmuxWindows()
    if (wins.has(name)) return true
  }
  // Check opencode session freshness
  if (session?.session_id && session?.updated_at) {
    const age = Date.now() - new Date(session.updated_at).getTime()
    if (age < 15 * 60 * 1000) return true
  }
  return false
}

// --- API handlers ---

function getFleetStatus() {
  const agents = loadAgents(STATE_ROOT)
  const reg = loadRegistry(STATE_ROOT)

  const sessionByName = {}
  for (const s of Object.values(reg.sessions)) {
    if (s.name && (!sessionByName[s.name] || (s.created_at || 0) > (sessionByName[s.name].created_at || 0))) {
      sessionByName[s.name] = s
    }
  }

  const merged = []

  // Add orchestrator
  let orch = {}
  try { orch = JSON.parse(readFileSync(path.join(STATE_ROOT, "orchestrator.json"), "utf8")) } catch {}
  if (orch.profile_id) {
    merged.push({
      name: "cairn",
      harness: orch.harness || "claude-code",
      model: orch.model || "opus-4.6",
      role: "orchestrator",
      alive: isAlive({ tmux_session: orch.tmux_session, tmux_window: orch.tmux_window }, "cairn"),
      status: "alive",
      tmux_session: orch.tmux_session || "openfleet",
      tmux_window: orch.tmux_window || "cairn",
      directory: orch.workdir || null,
      updated_at: orch.activated_at || null,
    })
  }

  for (const [name, agent] of Object.entries(agents)) {
    const session = sessionByName[name]
    const alive = session ? isAlive(session, name) : isAlive(null, name)
    const role = agent.role || session?.role || "ephemeral"
    merged.push({
      name,
      harness: agent.harness || session?.harness || null,
      model: agent.model || session?.model || null,
      role,
      alive,
      status: alive ? "alive" : role === "persistent" ? "dormant" : "dead",
      tmux_session: session?.tmux_session || null,
      tmux_window: session?.tmux_window || null,
      directory: agent.directory || session?.directory || null,
      updated_at: session?.updated_at || agent.updated_at || null,
    })
    delete sessionByName[name]
  }

  for (const [name, session] of Object.entries(sessionByName)) {
    const alive = isAlive(session, name)
    merged.push({
      name,
      harness: session.harness || null,
      model: session.model || null,
      role: session.role || "ephemeral",
      alive,
      status: alive ? "alive" : "dead",
      tmux_session: session.tmux_session || null,
      tmux_window: session.tmux_window || null,
      directory: session.directory || null,
      updated_at: session.updated_at || null,
      unregistered: true,
    })
  }

  return {
    uptime_ms: Date.now() - START_TIME,
    agent_count: merged.length,
    alive_count: merged.filter(a => a.alive).length,
    agents: merged.sort((a, b) => a.name.localeCompare(b.name)),
  }
}

function getTasksData() {
  const tasks = listTasks(STATE_ROOT)
  const blockers = listBlockers(STATE_ROOT)
  const approvals = listApprovals(STATE_ROOT)
  return { tasks, blockers, approvals }
}

function getEventsData() {
  const events = readEvents(STATE_ROOT)
  return events.slice(-50).reverse()
}

function getCronData() {
  const cronStatePath = path.join(STATE_ROOT, "cron-state.json")
  let lastFired = {}
  try { lastFired = JSON.parse(fs.readFileSync(cronStatePath, "utf8")) } catch {}

  const schedule = [
    { id: "stock-monitor-spawn", schedule: "9:25 M-F", description: "Spawn stock monitor" },
    { id: "stock-monitor-kill", schedule: "16:05 M-F", description: "Market close signal" },
    { id: "monitor-health-check", schedule: "every 2h", description: "VPS health check" },
    { id: "trader-scan", schedule: "every 4h", description: "Prediction market scan" },
    { id: "heartbeat", schedule: "every 1h", description: "Orchestrator heartbeat" },
  ]

  return schedule.map(s => ({
    ...s,
    last_fired: lastFired[s.id] || null,
  }))
}

function sendKeysToAgent(agentName, keys) {
  const target = resolveAgentTmux(agentName)
  if (!target) return { ok: false, error: "No tmux session for agent" }
  try {
    // Send literal keys — each character goes as a keystroke
    for (const key of keys) {
      if (key === "\n" || key === "\r") {
        execFileSync("tmux", ["send-keys", "-t", `${target.session}:${target.window}`, "Enter"], { stdio: "ignore" })
      } else if (key === "\x7f" || key === "\b") {
        execFileSync("tmux", ["send-keys", "-t", `${target.session}:${target.window}`, "BSpace"], { stdio: "ignore" })
      } else if (key === "\x1b") {
        execFileSync("tmux", ["send-keys", "-t", `${target.session}:${target.window}`, "Escape"], { stdio: "ignore" })
      } else {
        execFileSync("tmux", ["send-keys", "-t", `${target.session}:${target.window}`, "-l", key], { stdio: "ignore" })
      }
    }
    return { ok: true }
  } catch (e) {
    return { ok: false, error: e.message }
  }
}

function resolveAgentTmux(agentName) {
  const reg = loadRegistry(STATE_ROOT)
  for (const s of Object.values(reg.sessions)) {
    if ((s.name === agentName || s.agent_id === agentName) && s.tmux_session && s.tmux_window) {
      return { session: s.tmux_session, window: s.tmux_window }
    }
  }
  try {
    const orch = JSON.parse(readFileSync(path.join(STATE_ROOT, "orchestrator.json"), "utf8"))
    if (agentName === "cairn") return { session: orch.tmux_session || "openfleet", window: orch.tmux_window || "cairn" }
  } catch {}
  const wins = getLiveTmuxWindows()
  if (wins.has(agentName)) return { session: "openfleet", window: agentName }
  return null
}

function capturePaneContent(agentName, cols) {
  const target = resolveAgentTmux(agentName)
  if (!target) return { error: "No tmux session for agent", content: "" }
  const tmuxSession = target.session
  const tmuxWindow = target.window

  try {
    const content = execFileSync("tmux", [
      "capture-pane", "-pt", `${tmuxSession}:${tmuxWindow}`,
      "-S", "-100", "-e",
    ], { encoding: "utf8", timeout: 5000 })
    return { content, agent: agentName }
  } catch (e) {
    return { error: e.message, content: "" }
  }
}

function sendMessageToAgent(agentName, message) {
  try {
    execFileSync("node", [
      path.join(BIN, "send"), agentName, message,
    ], { encoding: "utf8", timeout: 15000 })
    return { ok: true }
  } catch (e) {
    return { ok: false, error: e.message }
  }
}

function spawnAgent(body) {
  const spawnArgs = [path.join(BIN, "spawn"), body.name]
  if (body.harness) spawnArgs.push("--harness", body.harness)
  if (body.model) spawnArgs.push("--model", body.model)
  if (body.dir) spawnArgs.push("--dir", body.dir)
  if (body.bootstrap) spawnArgs.push("--bootstrap", body.bootstrap)

  try {
    const result = execFileSync("node", spawnArgs, { encoding: "utf8", timeout: 30000 })
    return JSON.parse(result)
  } catch (e) {
    return { ok: false, error: e.message }
  }
}

// --- SSE ---

const sseClients = new Map()

function tokensEqual(provided, expected) {
  if (typeof provided !== "string" || typeof expected !== "string") return false

  const providedBuffer = Buffer.from(provided)
  const expectedBuffer = Buffer.from(expected)
  if (providedBuffer.length !== expectedBuffer.length) return false

  return crypto.timingSafeEqual(providedBuffer, expectedBuffer)
}

function closeSSEClient(res) {
  sseClients.delete(res)
  try { res.end() } catch {}
}

function pruneUnauthorizedSSEClients() {
  const expectedToken = ensureAuthToken(STATE_ROOT)
  for (const [res, token] of sseClients.entries()) {
    if (!tokensEqual(token, expectedToken)) {
      closeSSEClient(res)
    }
  }
}

function broadcastSSE(event, data) {
  const msg = `event: ${event}\ndata: ${JSON.stringify(data)}\n\n`
  for (const res of sseClients.keys()) {
    try { res.write(msg) } catch { closeSSEClient(res) }
  }
}

// Push status + events every 5 seconds
setInterval(() => {
  pruneUnauthorizedSSEClients()
  if (sseClients.size === 0) return
  try {
    broadcastSSE("status", getFleetStatus())
    broadcastSSE("events", getEventsData())
  } catch {}
}, SSE_INTERVAL_MS)

// --- HTTP Server ---

function readBody(req) {
  return new Promise((resolve, reject) => {
    const chunks = []
    req.on("data", c => chunks.push(c))
    req.on("end", () => {
      try { resolve(JSON.parse(Buffer.concat(chunks).toString())) }
      catch { resolve({}) }
    })
    req.on("error", reject)
  })
}

function json(res, data, status = 200) {
  res.writeHead(status, {
    "Content-Type": "application/json",
    "Access-Control-Allow-Origin": "*",
  })
  res.end(JSON.stringify(data))
}

function text(res, data, status = 200) {
  res.writeHead(status, {
    "Content-Type": "text/plain",
    "Access-Control-Allow-Origin": "*",
  })
  res.end(data)
}

function unauthorized(res) {
  return json(res, { error: "Unauthorized" }, 401)
}

function readBearerToken(req) {
  const header = req.headers.authorization || ""
  const match = header.match(/^Bearer\s+(.+)$/i)
  return match ? match[1].trim() : null
}

function isAuthorizedDashboardRequest(req, url) {
  const expectedToken = ensureAuthToken(STATE_ROOT)
  if (!expectedToken) return false

  if (url.pathname === "/api/stream") {
    return tokensEqual(url.searchParams.get("token"), expectedToken)
  }

  return tokensEqual(readBearerToken(req), expectedToken)
}

const MIME = {
  ".html": "text/html",
  ".css": "text/css",
  ".js": "application/javascript",
  ".json": "application/json",
  ".map": "application/json",
}

ensureAuthToken(STATE_ROOT)

const server = http.createServer(async (req, res) => {
  const url = new URL(req.url, `http://${req.headers.host}`)
  const pathname = url.pathname

  // CORS preflight
  if (req.method === "OPTIONS") {
    res.writeHead(204, {
      "Access-Control-Allow-Origin": "*",
      "Access-Control-Allow-Methods": "GET, POST, OPTIONS",
      "Access-Control-Allow-Headers": "Content-Type, Authorization",
    })
    return res.end()
  }

  try {
    if (pathname.startsWith("/api/") && !isAuthorizedDashboardRequest(req, url)) {
      return unauthorized(res)
    }

    // --- Routes ---

    // Root -> dashboard.html
    if (pathname === "/" && req.method === "GET") {
      const html = fs.readFileSync(path.join(CORE, "dashboard.html"), "utf8")
      res.writeHead(200, { "Content-Type": "text/html" })
      return res.end(html)
    }

    // API: fleet status
    if (pathname === "/api/status" && req.method === "GET") {
      return json(res, getFleetStatus())
    }

    // API: tasks
    if (pathname === "/api/tasks" && req.method === "GET") {
      return json(res, getTasksData())
    }

    // API: events
    if (pathname === "/api/events" && req.method === "GET") {
      return json(res, getEventsData())
    }

    // API: cron
    if (pathname === "/api/cron" && req.method === "GET") {
      return json(res, getCronData())
    }

    // API: capture agent pane
    const paneMatch = pathname.match(/^\/api\/agents\/([^/]+)\/pane$/)
    if (paneMatch && req.method === "GET") {
      const cols = parseInt(url.searchParams?.get("cols") || "120")
      const result = capturePaneContent(decodeURIComponent(paneMatch[1]), cols)
      if (result.error) return text(res, result.content || "", result.content ? 200 : 404)
      return text(res, result.content)
    }

    // API: send keystrokes to agent tmux pane (live typing)
    const keysMatch = pathname.match(/^\/api\/agents\/([^/]+)\/keys$/)
    if (keysMatch && req.method === "POST") {
      const body = await readBody(req)
      const result = sendKeysToAgent(decodeURIComponent(keysMatch[1]), body.keys || "")
      return json(res, result, result.ok ? 200 : 500)
    }

    // API: send message to agent
    const sendMatch = pathname.match(/^\/api\/agents\/([^/]+)\/send$/)
    if (sendMatch && req.method === "POST") {
      const body = await readBody(req)
      const result = sendMessageToAgent(decodeURIComponent(sendMatch[1]), body.message || "")
      return json(res, result, result.ok ? 200 : 500)
    }

    // API: spawn agent
    if (pathname === "/api/agents/spawn" && req.method === "POST") {
      const body = await readBody(req)
      const result = spawnAgent(body)
      return json(res, result, result.ok === false ? 500 : 200)
    }

    // SSE: event stream
    if (pathname === "/api/stream" && req.method === "GET") {
      res.writeHead(200, {
        "Content-Type": "text/event-stream",
        "Cache-Control": "no-cache",
        "Connection": "keep-alive",
        "Access-Control-Allow-Origin": "*",
      })
      res.write(`event: status\ndata: ${JSON.stringify(getFleetStatus())}\n\n`)
      sseClients.set(res, url.searchParams.get("token"))
      req.on("close", () => sseClients.delete(res))
      return
    }

    // Serve node_modules (for xterm CSS/JS)
    if (pathname.startsWith("/node_modules/")) {
      const filePath = path.join(NODE_MODULES, pathname.slice("/node_modules/".length))
      const safePath = path.resolve(filePath)
      if (!safePath.startsWith(NODE_MODULES)) {
        res.writeHead(403)
        return res.end("Forbidden")
      }
      if (fs.existsSync(safePath)) {
        const ext = path.extname(safePath)
        const contentType = MIME[ext] || "application/octet-stream"
        res.writeHead(200, { "Content-Type": contentType })
        return res.end(fs.readFileSync(safePath))
      }
    }

    // 404
    res.writeHead(404, { "Content-Type": "text/plain" })
    res.end("Not found")

  } catch (e) {
    console.error(`[dashboard] Error handling ${req.method} ${pathname}:`, e.message)
    res.writeHead(500, { "Content-Type": "text/plain" })
    res.end("Internal server error")
  }
})

server.listen(PORT, () => {
  console.log(`OpenFleet Dashboard: http://localhost:${PORT}`)
  console.log(`State dir: ${STATE_ROOT}`)
})

process.on("SIGINT", () => process.exit(0))
process.on("SIGTERM", () => process.exit(0))
