#!/usr/bin/env node

const os = require("os")
const path = require("path")
const { parseArgs } = require("../lib/opencode")
const { dispatchJob } = require("../core/dispatch")

function main() {
  const args = parseArgs(process.argv.slice(2))
  const stateRoot = args["state-root"] || process.env.OPENFLEET_CANONICAL_STATE_DIR || path.join(os.homedir(), ".openfleet")
  const allowed = args.allowed ? String(args.allowed).split(",").filter(Boolean) : []
  const input = args.input ? JSON.parse(args.input) : null

  const result = dispatchJob(stateRoot, {
    type: args.type,
    agent: args.agent,
    workflow_id: args.workflow,
    trigger: args.trigger,
    preferred_profile: args.preferred,
    allowed_profiles: allowed,
    role: args.role,
    harness: args.harness,
    input,
  })

  process.stdout.write(`${JSON.stringify(result, null, 2)}\n`)
}

try {
  main()
} catch (error) {
  console.error(error.message)
  process.exit(1)
}
