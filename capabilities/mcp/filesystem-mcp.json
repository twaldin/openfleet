{
  "name": "filesystem-mcp",
  "type": "mcp",
  "description": "Expose the current workspace through a filesystem MCP server.",
  "projections": {
    "claude-code": {
      "type": "json",
      "content": {
        "path": ".claude/mcp/filesystem.json",
        "value": {
          "transport": "stdio",
          "command": [
            "npx",
            "-y",
            "@modelcontextprotocol/server-filesystem",
            "."
          ]
        }
      }
    },
    "opencode": {
      "type": "json",
      "content": {
        "path": ".opencode/mcp/filesystem.json",
        "value": {
          "transport": "stdio",
          "command": [
            "npx",
            "-y",
            "@modelcontextprotocol/server-filesystem",
            "."
          ]
        }
      }
    },
    "codex": {
      "type": "json",
      "content": {
        "path": ".codex/mcp/filesystem.json",
        "value": {
          "transport": "stdio",
          "command": [
            "npx",
            "-y",
            "@modelcontextprotocol/server-filesystem",
            "."
          ]
        }
      }
    }
  }
}
