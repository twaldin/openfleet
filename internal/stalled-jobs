#!/usr/bin/env node

const os = require('os')
const path = require('path')
const { execFileSync } = require('child_process')
const { parseArgs } = require('../lib/opencode')
const { listStalledJobs } = require('../core/stalled')
const { loadDeploymentConfig } = require('../core/deployment')

async function main() {
  const args = parseArgs(process.argv.slice(2))
  const [command, id] = args._
  const stateRoot = args['state-root'] || process.env.OPENFLEET_CANONICAL_STATE_DIR || path.join(os.homedir(), '.openfleet')

  const stalledOpts = {}
  const deploymentPath = args.deployment || process.env.OPENFLEET_DEPLOYMENT
  if (deploymentPath) {
    const deployment = loadDeploymentConfig(deploymentPath)
    stalledOpts.serverStateDir = deployment.server.stateDir
    stalledOpts.serverLogDir = deployment.server.logDir
  }

  if (!command || command === 'list') {
    const stalled = await listStalledJobs(stateRoot, stalledOpts)
    process.stdout.write(`${JSON.stringify(stalled, null, 2)}\n`)
    return
  }

  if (command === 'nudge') {
    const stalled = await listStalledJobs(stateRoot, stalledOpts)
    const match = stalled.find((item) => item.job.id === id)
    if (!match) throw new Error(`No stalled job found for ${id}`)

    const sessionName = match.job.output?.execution?.session || match.metadata.name
    const prompt = `SYSTEM: Your latest turn appears finished, but job ${match.job.id} is still in progress. If the work is complete, call report-completion now. Otherwise continue the job immediately.`
    const sendBin = path.join(__dirname, '..', 'bin', 'send')
    execFileSync('node', [sendBin, sessionName, '--message', prompt], { encoding: 'utf8' })
    process.stdout.write(JSON.stringify({ ok: true, nudged: id, session: sessionName }, null, 2) + '\n')
    return
  }

  throw new Error('Usage: stalled-jobs [list|nudge <job-id>]')
}
main().catch((error) => {
  console.error(error.message)
  process.exit(1)
})
