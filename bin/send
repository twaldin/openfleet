#!/usr/bin/env node
// Universal message sender — routes to any agent regardless of harness
const { execFileSync } = require("child_process")
const os = require("os")
const path = require("path")
const fs = require("fs")
const { parseArgs } = require("../lib/opencode")
const { sendMessage } = require("../core/harness/openclaw")
const { hashAgentPort } = require("../core/remote/ssh")
const { loadRegistry } = require("../core/runtime/registry")
const { loadActiveOrchestrator } = require("../core/runtime/orchestrator")
const { createEventStore } = require("../core/runtime/events")

async function main() {
  const args = parseArgs(process.argv.slice(2))
  const stateRoot = args["state-root"] || process.env.OPENFLEET_CANONICAL_STATE_DIR || path.join(os.homedir(), ".openfleet")
  const direction = args.direction || "parent_to_worker"

  // Handle --to-parent mode (flag parsed by parseArgs, not positional)
  if (args["to-parent"]) {
    const message = args._.join(" ").trim() || args.message || ""
    if (!message) {
      console.error("Usage: send --to-parent --sender <name> --message \"text\"")
      process.exit(1)
    }
    return await sendToParent(stateRoot, message, args.sender)
  }

  const target = args._[0]
  const message = args._.slice(1).join(" ").trim() || args.message || ""

  if (!target || !message) {
    console.error("Usage: send <agent-name> --message \"text\" [--sender <name>]")
    console.error("       send --to-parent --sender <name> --message \"text\"")
    process.exit(1)
  }

  // Look up agent in registry
  const orchestrator = loadActiveOrchestrator(stateRoot)
  if (isParentTarget(target, orchestrator)) {
    return await sendToParent(stateRoot, message, args.sender)
  }

  const registry = loadRegistry(stateRoot)
  const session = findAgentSession(registry, target)

  if (!session) {
    console.error(`Agent '${target}' not found in registry. Known agents:`)
    Object.values(registry.sessions).forEach(s => {
      if (s.name) console.error(`  ${s.name} (${s.harness || "unknown"})`)
    })
    process.exit(1)
  }

  const fullMessage = applyMessageProvenance(message, { sender: args.sender })
  const routed = await routeMessage(session, fullMessage, { targetName: target, stateRoot })

  if (routed.transport === "openclaw") {
    console.log(`Sent to ${target} via OpenClaw HTTP :${routed.port}`)
  } else if (routed.transport === "opencode") {
    console.log(`Sent to ${target} via opencode run --attach :${routed.port}`)
  } else if (routed.transport === "tmux") {
    console.log(`Sent to ${target} via tmux @ ${routed.target}`)
  }

  // Emit event
  createEventStore(stateRoot).append({
    type: "message.created",
    session_id: session.session_id,
    agent_id: target,
    payload: { direction, text: fullMessage },
  })
}

async function sendToParent(stateRoot, message, sender) {
  const orchestrator = loadActiveOrchestrator(stateRoot)
  if (!orchestrator) {
    console.error("No active orchestrator registered")
    process.exit(1)
  }

  const fullMessage = applyMessageProvenance(message, { sender })
  const resolvedSender = resolveSenderName({ sender })

  if (orchestrator.harness === "openclaw") {
    const port = orchestrator.openclaw_port || hashAgentPort(orchestrator.name || orchestrator.agent_id || "parent")
    if (!orchestrator.openclaw_token) {
      console.error("Cannot route to parent: missing OpenClaw auth token")
      process.exit(1)
    }
    await sendMessage(port, orchestrator.openclaw_token, fullMessage)
  } else if (orchestrator.harness === "opencode" && orchestrator.session_id) {
    const baseUrl = process.env.OPENCODE_URL || "http://127.0.0.1:4096"
    const url = `${baseUrl}/session/${orchestrator.session_id}/prompt_async?directory=${encodeURIComponent(orchestrator.workdir || "")}`
    const payload = JSON.stringify({ parts: [{ type: "text", text: fullMessage }] })
    execFileSync("curl", ["--max-time", "10", "-sS", "-X", "POST", "-H", "Content-Type: application/json", "-d", payload, url], { encoding: "utf8" })
  } else if (orchestrator.tmux_session && orchestrator.tmux_window) {
    sendViaTmux(orchestrator.tmux_session, orchestrator.tmux_window, fullMessage)
  } else {
    console.error("Cannot route to parent: no transport available")
    process.exit(1)
  }

  createEventStore(stateRoot).append({
    type: "message.created",
    agent_id: (resolvedSender || "unknown").toLowerCase(),
    payload: { direction: "worker_to_parent", text: fullMessage },
  })

  console.log(`Sent to parent (${orchestrator.harness})`)
}

async function routeMessage(session, message, {
  targetName = session.name || session.agent_id || session.tmux_window,
  stateRoot = process.env.OPENFLEET_CANONICAL_STATE_DIR || path.join(os.homedir(), ".openfleet"),
  hasTmuxWindowImpl = hasTmuxWindow,
  sendOpenClawImpl = sendMessage,
  sendTmuxImpl = sendViaTmux,
} = {}) {
  const harness = session.harness || "opencode"
  const tmuxSession = session.tmux_session
  const tmuxWindow = session.tmux_window

  if (harness === "openclaw") {
    const port = session.openclaw_port || hashAgentPort(targetName)
    if (!session.openclaw_token) {
      throw new Error(`Cannot route message to ${targetName}: missing OpenClaw auth token`)
    }
    await sendOpenClawImpl(port, session.openclaw_token, message)
    return { transport: "openclaw", port }
  }

  if (harness === "opencode") {
    const dir = (session.directory || session.workspace || path.join(stateRoot, "agents", targetName)).replace(/^~/, os.homedir())
    const port = session.opencode_port || hashAgentPort(targetName)
    sendViaOpencodeRun(dir, message, port, targetName)
    return { transport: "opencode", port }
  }

  if (tmuxSession && tmuxWindow && hasTmuxWindowImpl(tmuxSession, tmuxWindow)) {
    sendTmuxImpl(tmuxSession, tmuxWindow, message)
    return { transport: "tmux", target: `${tmuxSession}:${tmuxWindow}` }
  }

  throw new Error(`Cannot route message to ${targetName}: no tmux coords or harness transport`)
}

function isParentTarget(target, orchestrator) {
  if (target === "parent" || target === "orchestrator") {
    return true
  }

  return Boolean(orchestrator?.tmux_window && target === orchestrator.tmux_window)
}

function findAgentSession(registry, name) {
  // First try by name
  for (const session of Object.values(registry.sessions)) {
    if (session.name === name || session.agent_id === name) return session
  }
  return null
}

function sendViaTmux(session, window, message) {
  const target = `${session}:${window}`
  // Use load-buffer for long messages to avoid shell escaping issues
  if (message.length > 500) {
    const tmp = path.join(os.tmpdir(), `openfleet-send-${Date.now()}.txt`)
    fs.writeFileSync(tmp, message)
    execFileSync("tmux", ["load-buffer", tmp], { stdio: "ignore" })
    execFileSync("tmux", ["paste-buffer", "-t", target], { stdio: "ignore" })
    fs.unlinkSync(tmp)
  } else {
    execFileSync("tmux", ["send-keys", "-t", target, "-l", message], { stdio: "ignore" })
  }
  // Small delay then Enter — Codex TUI sometimes needs a moment after paste
  sleep(300)
  execFileSync("tmux", ["send-keys", "-t", target, "Enter"], { stdio: "ignore" })
  // Second Enter after delay — catches Codex/Claude prompts that need confirmation
  sleep(200)
  execFileSync("tmux", ["send-keys", "-t", target, "Enter"], { stdio: "ignore" })
}

function sleep(ms) {
  Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, ms)
}

function sendViaOpencodeRun(dir, message, port, agentName) {
  // Use `opencode run --attach` — official API, reliable, shows in TUI, handles long messages
  try {
    execFileSync("opencode", [
      "run", "--attach", `http://127.0.0.1:${port}`,
      "--dir", dir,
      "--format", "json",
      message,
    ], { encoding: "utf8", timeout: 30000, stdio: "pipe" })
  } catch {
    // Fallback to TUI API for backward compat
    const baseUrl = `http://127.0.0.1:${port}`
    execFileSync("curl", [
      "-sS", "--max-time", "5", "-X", "POST", `${baseUrl}/tui/append-prompt`,
      "-H", "Content-Type: application/json",
      "-d", JSON.stringify({ text: message }),
    ], { encoding: "utf8" })
    sleep(1000)
    execFileSync("curl", [
      "-sS", "--max-time", "5", "-X", "POST", `${baseUrl}/tui/submit-prompt`,
    ], { encoding: "utf8" })
  }
}

function hasTmuxWindow(session, window) {
  try {
    execFileSync("tmux", ["has-session", "-t", session], { stdio: "ignore" })
    const wins = execFileSync("tmux", ["list-windows", "-t", session, "-F", "#{window_name}"], { encoding: "utf8" })
    return wins.split("\n").includes(window)
  } catch { return false }
}

function applyMessageProvenance(message, options = {}) {
  const text = String(message || "")
  if (hasSourcePrefix(text)) {
    return text
  }

  const sender = resolveSenderName(options)
  return `[${sender.toUpperCase()}] ${text}`
}

function hasSourcePrefix(message) {
  return /^\[[^\]\n]+\]\s/.test(message)
}

function resolveSenderName({ sender, env = process.env, execFileSyncImpl = execFileSync } = {}) {
  if (sender) {
    return sender
  }

  if (env.OPENFLEET_AGENT_NAME) {
    return env.OPENFLEET_AGENT_NAME
  }

  if (env.AGENT_NAME) {
    return env.AGENT_NAME
  }

  const tmuxWindow = resolveTmuxWindowName({ env, execFileSyncImpl })
  if (tmuxWindow) {
    return tmuxWindow
  }

  return "UNKNOWN"
}

function resolveTmuxWindowName({ env = process.env, execFileSyncImpl = execFileSync } = {}) {
  if (!env.TMUX && !env.TMUX_PANE) {
    return null
  }

  const args = ["display-message", "-p"]
  if (env.TMUX_PANE) {
    args.push("-t", env.TMUX_PANE)
  }
  args.push("#{window_name}")

  try {
    const output = execFileSyncImpl("tmux", args, { encoding: "utf8", stdio: "pipe" }).trim()
    return output || null
  } catch {
    return null
  }
}

if (require.main === module) {
  main().catch((e) => {
    console.error(e.message)
    process.exit(1)
  })
}

module.exports = {
  applyMessageProvenance,
  findAgentSession,
  hasTmuxWindow,
  hasSourcePrefix,
  isParentTarget,
  main,
  routeMessage,
  resolveSenderName,
  resolveTmuxWindowName,
  sendToParent,
}
