#!/usr/bin/env node

const { ensureOpencodeServer, parseArgs } = require("../lib/opencode")

async function main() {
  const args = parseArgs(process.argv.slice(2))
  const host = args.host || process.env.OPENFLEET_SERVER_HOST || process.env.OPENCODE_SERVER_HOST || "127.0.0.1"
  const port = args.port || process.env.OPENFLEET_SERVER_PORT || process.env.OPENCODE_SERVER_PORT || "4096"
  const stateDir = args["state-dir"] || process.env.OPENFLEET_SERVER_STATE_DIR || process.env.OPENCODE_STATE_DIR
  const logDir = args["log-dir"] || process.env.OPENFLEET_SERVER_LOG_DIR || process.env.OPENCODE_LOG_DIR

  if (!stateDir || !logDir) {
    throw new Error("Missing state/log directory configuration")
  }

  const baseUrl = await ensureOpencodeServer({ host, port, stateDir, logDir })
  process.stdout.write(`${baseUrl}\n`)
}

main().catch((error) => {
  console.error(error.message)
  process.exit(1)
})
