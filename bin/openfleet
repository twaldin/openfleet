#!/usr/bin/env node
// Unified openfleet CLI entrypoint
const { execFileSync } = require("child_process")
const path = require("path")

const binDir = __dirname

const commands = {
  // State queries
  status: () => run("ops", ["dashboard"]),
  agents: () => run("ops", ["agents"]),
  dashboard: () => run("ops", ["dashboard"]),
  summary: () => run("ops", ["summary"]),
  presence: () => run("ops", ["presence"]),
  watch: (args) => run("ops-ui", args),
  poll: (args) => run("discord-poll", args),

  // Task management
  task: (args) => run("task-state", args),
  dispatch: (args) => run("dispatch", args),
  execute: (args) => run("execute", args),
  spawn: (args) => run("spawn", args),
  merge: (args) => run("merge-worker", args),
  kill: (args) => killAgentWindow(args),

  // Job lifecycle
  "report-completion": (args) => run("report-completion", args),
  complete: (args) => run("report-completion", args),

  // Communication
  send: (args) => run("message_agent", args),
  message: (args) => run("message_agent", args),
  remote: (args) => run("remote", args),
  discord: (args) => run("remote", ["discord", ...args]),

  // Profiles
  profile: (args) => run("profile", args),
  profiles: () => run("profile", ["list"]),

  // Fleet lifecycle
  cron: (args) => run("cron", args),
  lifecycle: (args) => run("agent-lifecycle", args),
  respawn: (args) => run("agent-lifecycle", ["respawn", ...args]),
  compact: (args) => run("agent-lifecycle", ["compact", ...args]),

  // Setup
  init: (args) => run("init", args),

  // Maintenance
  maintenance: (args) => run("maintenance-loop", args),
  stalled: (args) => run("stalled-jobs", args),
  reconcile: (args) => run("reconcile-state", args),

  // Orchestrator
  orchestrator: (args) => run("orchestrator", args),
  mcp: (args) => run("mcp-server", args),
  gateway: (args) => run("discord-gateway", args),

  // Events
  events: (args) => run("ops", ["tail", ...(args || [])]),

  // Help
  help: () => {
    console.log(`openfleet — harness-agnostic agent orchestration

USAGE
  openfleet <command> [args...]

STATE
  status              Fleet dashboard overview
  agents              List all agents and health
  dashboard           Full dashboard
  summary             Compact summary
  presence            Agent presence/activity
  watch [args]        Interactive operations dashboard
  poll [args]         Poll Discord messages

TASKS
  task <subcommand>   Task lifecycle (create, list, update, etc.)
  dispatch [args]     Dispatch a job to an agent
  execute [args]      Execute a command or workflow
  spawn [args]        Spawn agents in any harness
  kill <name>         Kill tmux window openfleet:<name>

JOBS
  report-completion <job-id>  Report job completion
  complete <job-id>           Alias for report-completion

COMMUNICATION
  send <agent> <msg>          Message an agent
  message <agent> <msg>       Alias for send
  remote [args]               Remote operations
  discord <subcommand>        Discord operations (post, summary, etc.)

PROFILES
  profile <subcmd>    Runtime profile management
  profiles            List all runtime profiles

OPERATIONS
  maintenance [args]  Run maintenance loop
  stalled [args]      Check for stalled jobs
  reconcile [args]    Reconcile fleet state
  orchestrator [args] Orchestrator controls
  events [args]       Tail event log
  mcp [args]          Start MCP server

SETUP
  init                Interactive setup wizard

HELP
  help                Show this help
`)
  },
}

function run(script, args = []) {
  const scriptPath = path.join(binDir, script)
  try {
    execFileSync("node", [scriptPath, ...args], { stdio: "inherit" })
  } catch (e) {
    process.exit(e.status || 1)
  }
}

function killAgentWindow(args = []) {
  const name = args[0]
  if (!name) {
    console.error("Usage: openfleet kill <name>")
    process.exit(1)
  }

  try {
    execFileSync("tmux", ["kill-window", "-t", `openfleet:${name}`], { stdio: "inherit" })
  } catch (e) {
    process.exit(e.status || 1)
  }
}

function main() {
  const args = process.argv.slice(2)
  const command = args[0]
  const rest = args.slice(1)

  if (!command || command === "help" || command === "--help" || command === "-h") {
    commands.help()
    return
  }

  const handler = commands[command]
  if (!handler) {
    console.error(`Unknown command: ${command}`)
    console.error(`Run 'openfleet help' for usage`)
    process.exit(1)
  }

  handler(rest)
}

main()
