#!/usr/bin/env node

const os = require('os')
const path = require('path')
const { listTasks, updateTask } = require('../core/runtime/tasks')
const { listJobs } = require('../core/runtime/jobs')
const { createEventStore } = require('../core/runtime/events')

function main() {
  const stateRoot = process.env.OPENFLEET_CANONICAL_STATE_DIR || path.join(os.homedir(), '.openfleet')
  const eventStore = createEventStore(stateRoot)
  const updated = []
  const jobs = listJobs(stateRoot)

  for (const task of listTasks(stateRoot)) {
    const relatedJobs = jobs.filter((job) => job.input?.task_id === task.id || job.input?.context?.task_id === task.id)
    if (relatedJobs.some((job) => ['running', 'dispatched', 'assigned', 'queued'].includes(job.status)) && task.status === 'open') {
      const next = updateTask(stateRoot, task.id, { status: 'in_progress' })
      eventStore.append({ type: 'task.updated', agent_id: next.assignee || 'openfleet', payload: next })
      updated.push(next)
      continue
    }

    if (relatedJobs.length > 0 && relatedJobs.every((job) => job.status === 'completed') && task.status !== 'completed') {
      const next = updateTask(stateRoot, task.id, { status: 'completed' })
      eventStore.append({ type: 'task.updated', agent_id: next.assignee || 'openfleet', payload: next })
      updated.push(next)
    }
  }

  process.stdout.write(`${JSON.stringify({ ok: true, updated }, null, 2)}\n`)
}

try {
  main()
} catch (error) {
  console.error(error.message)
  process.exit(1)
}
