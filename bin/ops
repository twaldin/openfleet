#!/usr/bin/env node

const os = require("os")
const path = require("path")
const { parseArgs } = require("../lib/opencode")
const { buildCaptureSurface, buildDashboard, buildDashboardSurface, buildFollowSurface, buildSummary, defaultStateRoot, fetchSessionMessages, inspectAgent, listAgentMetadata, renderListSurface, renderMessages } = require("../core/ops")
const { listJobs, getJob } = require("../core/runtime/jobs")
const { listWorkflows, getWorkflow } = require("../core/runtime/workflows")
const { listTasks, getTask } = require("../core/runtime/tasks")
const { listBlockers, getBlocker } = require("../core/runtime/blockers")
const { listApprovals, getApproval } = require("../core/runtime/approvals")

async function main() {
  const args = parseArgs(process.argv.slice(2))
  const [subcommand, target] = args._
  const stateRoot = args["state-root"] || process.env.OPENFLEET_CANONICAL_STATE_DIR || defaultStateRoot()
  const host = args.host || process.env.OPENFLEET_SERVER_HOST || process.env.OPENCODE_SERVER_HOST || "127.0.0.1"
  const port = args.port || process.env.OPENFLEET_SERVER_PORT || process.env.OPENCODE_SERVER_PORT || "4096"
  const serverStateDir = args["server-state-dir"] || process.env.OPENFLEET_SERVER_STATE_DIR || path.join(os.homedir(), ".cairn", "system", "opencode")
  const serverLogDir = args["server-log-dir"] || process.env.OPENFLEET_SERVER_LOG_DIR || path.join(os.homedir(), ".cairn", "system", "logs")
  const json = Boolean(args.json)
  const limit = Number(args.limit || 20)

  switch (subcommand) {
    case "agents": {
      const items = listAgentMetadata(stateRoot)
      return output(items, json)
    }
    case "dashboard": {
      return output(buildDashboard(stateRoot), json, { surface: buildDashboardSurface(stateRoot) })
    }
    case "summary": {
      process.stdout.write(`${buildSummary(stateRoot)}\n`)
      return
    }
    case "inspect": {
      if (!target) throw new Error("Usage: ops inspect <agent>")
      const result = inspectAgent(stateRoot, target, limit)
      return output(result, json)
    }
    case "tail":
    case "capture": {
      if (!target) throw new Error(`Usage: ops ${subcommand} <agent>`) 
      const { metadata } = inspectAgent(stateRoot, target, limit)
      const messages = await fetchSessionMessages({ metadata, host, port, serverStateDir, serverLogDir })
      const rendered = renderMessages(messages, limit)
      if (json) return output({ metadata, messages: rendered }, true)
      process.stdout.write(`${buildCaptureSurface({ metadata, messages: rendered })}\n`)
      return
    }
    case "follow": {
      if (!target) throw new Error("Usage: ops follow <agent>")
      const { metadata } = inspectAgent(stateRoot, target, limit)
      let lastCount = 0
      const tick = async () => {
        const messages = await fetchSessionMessages({ metadata, host, port, serverStateDir, serverLogDir })
        const rendered = renderMessages(messages, limit)
        const delta = rendered.slice(lastCount)
        lastCount = rendered.length
        if (delta.length) {
          if (json) {
            output({ metadata, messages: delta }, true)
          } else {
            process.stdout.write(`${buildFollowSurface({ metadata, messages: rendered, lastCount: rendered.length - delta.length })}\n`)
          }
        }
      }
      await tick()
      setInterval(() => {
        tick().catch((error) => {
          console.error(error.message)
        })
      }, 2000)
      return
    }
    case "jobs": {
      return output(listJobs(stateRoot), json)
    }
    case "job": {
      if (!target) throw new Error("Usage: ops job <id>")
      return output(getJob(stateRoot, target), json)
    }
    case "workflows": {
      return output(listWorkflows(stateRoot), json)
    }
    case "workflow": {
      if (!target) throw new Error("Usage: ops workflow <id>")
      return output(getWorkflow(stateRoot, target), json)
    }
    case "tasks": {
      return output(listTasks(stateRoot), json)
    }
    case "task": {
      if (!target) throw new Error("Usage: ops task <id>")
      return output(getTask(stateRoot, target), json)
    }
    case "blockers": {
      return output(listBlockers(stateRoot), json)
    }
    case "blocker": {
      if (!target) throw new Error("Usage: ops blocker <id>")
      return output(getBlocker(stateRoot, target), json)
    }
    case "approvals": {
      return output(listApprovals(stateRoot), json)
    }
    case "approval": {
      if (!target) throw new Error("Usage: ops approval <id>")
      return output(getApproval(stateRoot, target), json)
    }
    default:
      throw new Error("Usage: ops <dashboard|summary|agents|inspect|tail|follow|capture|jobs|job|workflows|workflow|tasks|task|blockers|blocker|approvals|approval> [target] [--json] [--limit N]")
  }
}

function output(value, json, options = {}) {
  if (json) {
    process.stdout.write(`${JSON.stringify(value, null, 2)}\n`)
    return
  }

  if (options.surface) {
    process.stdout.write(`${options.surface}\n`)
    return
  }

  if (Array.isArray(value)) {
    process.stdout.write(`${renderListSurface(value)}\n`)
    return
  }

  if (value.metadata && value.messages) {
    process.stdout.write(`agent=${value.metadata.name} session=${value.metadata.sessionID || "-"} model=${value.metadata.agentProfile || "-"} location=${value.metadata.location || "-"} host=${value.metadata.host || "-"} baseUrl=${value.metadata.baseUrl || "-"}\n`)
    for (const msg of value.messages) {
      process.stdout.write(`\n[${msg.role || "unknown"}] provider=${msg.provider || "-"} model=${msg.model || "-"} finish=${msg.finish || "-"}\n`)
      if (msg.text) {
        process.stdout.write(`${msg.text}\n`)
      } else {
        process.stdout.write(`parts=${msg.partTypes.join(",")}\n`)
      }
    }
    return
  }

  if (value.metadata && value.events) {
    process.stdout.write(`${JSON.stringify(value, null, 2)}\n`)
    return
  }

  if (value.counts && value.agents) {
    process.stdout.write(`${JSON.stringify(value, null, 2)}\n`)
    return
  }

  process.stdout.write(`${JSON.stringify(value, null, 2)}\n`)
}

main().catch((error) => {
  console.error(error.message)
  process.exit(1)
})
