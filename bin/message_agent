#!/usr/bin/env node

const os = require("os")
const path = require("path")
const { ensureOpencodeServer, parseArgs, request, readJson } = require("../lib/opencode")
const { loadSessionMetadata } = require("../core/runtime/session")
const { createEventStore } = require("../core/runtime/events")

async function main() {
  const args = parseArgs(process.argv.slice(2))
  const name = args._[0]
  const message = args._.slice(1).join(" ").trim()
  const workspaceRoot = args["workspace-root"] || process.env.OPENFLEET_WORKSPACE_ROOT || path.join(os.homedir(), "cairn")
  const stateDir = args["state-dir"] || process.env.OPENFLEET_STATE_DIR || path.join(os.homedir(), ".openfleet", "system", "opencode", "workers")
  const canonicalStateDir = args["canonical-state-dir"] || process.env.OPENFLEET_CANONICAL_STATE_DIR || null
  const workerSessionScript = args["worker-session-script"] || process.env.OPENFLEET_WORKER_SESSION_SCRIPT
  const host = args.host || process.env.OPENFLEET_SERVER_HOST || process.env.OPENCODE_SERVER_HOST || "127.0.0.1"
  const port = args.port || process.env.OPENFLEET_SERVER_PORT || process.env.OPENCODE_SERVER_PORT || "4096"
  const agentProfile = args.agent || process.env.OPENFLEET_AGENT_PROFILE || "worker"
  const serverStateDir = args["server-state-dir"] || process.env.OPENFLEET_SERVER_STATE_DIR || path.join(os.homedir(), ".openfleet", "system", "opencode")
  const serverLogDir = args["server-log-dir"] || process.env.OPENFLEET_SERVER_LOG_DIR || path.join(os.homedir(), ".openfleet", "system", "logs")

  if (!name || !message) {
    throw new Error("Usage: message_agent <name> <message>")
  }

  const baseUrl = process.env.OPENCODE_URL || await ensureOpencodeServer({ host, port, stateDir: serverStateDir, logDir: serverLogDir })

  const sessionID = await ensureWorkerSession(name, workerSessionScript, agentProfile)
  const worker = loadSessionMetadata(stateDir, name) || readJson(path.join(stateDir, `${name}.json`))
  const directory = worker?.directory || path.join(workspaceRoot, "agents", name)

  await request(baseUrl, "POST", `/session/${sessionID}/prompt_async`, {
    directory,
    body: {
      agent: worker?.agentProfile || agentProfile,
      parts: [{ type: "text", text: message }],
    },
  })

  if (canonicalStateDir) {
    createEventStore(canonicalStateDir).append({
      type: "message.created",
      session_id: sessionID,
      agent_id: name,
      payload: {
        direction: "parent_to_worker",
        text: message,
      },
    })
  }

  process.stdout.write(`Sent to ${name}\n`)
}

async function ensureWorkerSession(name, workerSessionScript, agentProfile) {
  if (workerSessionScript) {
    const { execFileSync } = require("child_process")
    const args = [name, "--id"]
    if (agentProfile) {
      args.push("--agent", agentProfile)
    }
    return execFileSync(workerSessionScript, args, { encoding: "utf8" }).trim()
  }

  const { execFileSync } = require("child_process")
  const script = path.join(__dirname, "worker_session")
  const args = [name, "--id"]
  if (agentProfile) {
    args.push("--agent", agentProfile)
  }
  return execFileSync(script, args, { encoding: "utf8" }).trim()
}

main().catch((error) => {
  console.error(error.message)
  process.exit(1)
})
