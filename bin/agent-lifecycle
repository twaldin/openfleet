#!/usr/bin/env node
// Agent lifecycle management — compact, check health, respawn dormant persistent agents
const { execFileSync } = require("child_process")
const fs = require("fs")
const os = require("os")
const path = require("path")
const { parseArgs } = require("../lib/opencode")
const { loadRegistry, saveRegistry } = require("../core/runtime/registry")
const { loadAgents, getAgent } = require("../core/runtime/agents")
const { createEventStore } = require("../core/runtime/events")

const STATE_ROOT = process.env.OPENFLEET_CANONICAL_STATE_DIR || path.join(os.homedir(), ".openfleet")
const BIN = __dirname

function main() {
  const args = parseArgs(process.argv.slice(2))
  const command = args._[0]

  if (command === "check") return checkAll()
  if (command === "respawn") return respawnDormant(args)
  if (command === "compact") return compactAgent(args)
  if (command === "status") return showStatus()
  if (command === "attach") return attachAll(args)

  console.error("Usage: agent-lifecycle <check|respawn|compact|status|attach>")
  console.error("  check     — check health of all registered agents")
  console.error("  respawn   — respawn dormant persistent agents")
  console.error("  compact   — tell an agent to compact its context")
  console.error("  status    — show detailed agent status")
  console.error("  attach    — create tmux windows for all active agents")
  process.exit(1)
}

function checkAll() {
  const reg = loadRegistry(STATE_ROOT)
  const events = createEventStore(STATE_ROOT)
  const results = []

  for (const session of Object.values(reg.sessions)) {
    if (!session.name) continue
    const alive = isAlive(session)
    const role = session.role || "ephemeral"
    results.push({ name: session.name, alive, role, harness: session.harness || "?" })

    if (!alive && role === "persistent") {
      console.log(`DORMANT persistent agent: ${session.name} (${session.harness}/${session.model})`)
    }
  }

  const aliveCount = results.filter(r => r.alive).length
  const dormantPersistent = results.filter(r => !r.alive && r.role === "persistent").length
  console.log(`\nFleet: ${aliveCount} alive, ${dormantPersistent} dormant persistent, ${results.length} total`)

  if (dormantPersistent > 0) {
    console.log("Run 'agent-lifecycle respawn' to bring persistent agents back online")
  }
}

function respawnDormant(args) {
  const specific = args._[1] // optional: respawn a specific agent
  const agents = loadAgents(STATE_ROOT)

  for (const [name, agent] of Object.entries(agents)) {
    if (agent.role !== "persistent") continue
    if (specific && name !== specific) continue

    // Check if already alive (has a tmux window)
    const effectiveSession = { tmux_session: "openfleet", tmux_window: name }
    if (isAlive(effectiveSession)) {
      console.log(`${name}: already alive, skipping`)
      continue
    }

    const harness = agent.harness || "opencode"
    const model = agent.model || "gpt-5.4"
    const dir = agent.directory || path.join(STATE_ROOT, "agents", name)
    const resolvedDir = dir.replace(/^~/, os.homedir())

    console.log(`Respawning ${name} (${harness}/${model})...`)

    // Build bootstrap prompt from workspace files
    const soulFile = path.join(resolvedDir, "SOUL.md")
    const stateFile = path.join(resolvedDir, "state.md")
    const memoryFile = path.join(resolvedDir, "MEMORY.md")

    const prompt = [
      `You are the persistent ${name} agent. You have been respawned.`,
      fs.existsSync(soulFile) ? `Read your identity: ${soulFile}` : "",
      fs.existsSync(stateFile) ? `Read your last state: ${stateFile}` : "",
      fs.existsSync(memoryFile) ? `Read your memory: ${memoryFile}` : "",
      `Resume your normal operations. Post a status update to your Discord channel using: node ~/openfleet/bin/post "your update"`,
    ].filter(Boolean).join("\n")

    try {
      // Use bin/spawn to create a real tmux window with the CLI running
      const result = execFileSync("node", [
        path.join(BIN, "spawn"), name,
        "--harness", harness,
        "--model", model,
        "--dir", resolvedDir,
        "--bootstrap", prompt,
      ], { encoding: "utf8", timeout: 60000 })

      const parsed = JSON.parse(result)

      createEventStore(STATE_ROOT).append({
        type: "agent.respawned",
        agent_id: name,
        payload: { session_id: parsed.session_id, harness, model },
      })

      console.log(`${name}: respawned (${parsed.session_id?.slice(0, 15) || "ok"})`)
    } catch (e) {
      console.error(`${name}: respawn failed — ${e.message}`)
    }
  }
}

function compactAgent(args) {
  const name = args._[1]
  if (!name) {
    console.error("Usage: agent-lifecycle compact <agent-name>")
    process.exit(1)
  }

  console.log(`Telling ${name} to compact...`)
  try {
    execFileSync("node", [
      path.join(BIN, "message_agent"), name,
      "--agent", name,
      "--canonical-state-dir", STATE_ROOT,
      "COMPACT: Save your current state to your state.md file, summarize what you were working on, then acknowledge compaction is complete. After saving state, you can be safely restarted.",
    ], { encoding: "utf8", timeout: 15000 })
    console.log(`Compact message sent to ${name}`)
  } catch (e) {
    console.error(`Failed to send compact to ${name}: ${e.message}`)
  }
}

function showStatus() {
  // Merge agents.json (canonical identity) with registry.json (live sessions)
  const agents = loadAgents(STATE_ROOT)
  const reg = loadRegistry(STATE_ROOT)

  // Build session lookup by name
  const sessionByName = {}
  for (const s of Object.values(reg.sessions)) {
    if (s.name && (!sessionByName[s.name] || (s.created_at || 0) > (sessionByName[s.name].created_at || 0))) {
      sessionByName[s.name] = s
    }
  }

  console.log("Agent".padEnd(20), "Harness".padEnd(12), "Model".padEnd(15), "Role".padEnd(12), "Status")
  console.log("-".repeat(70))

  // Show agents from agents.json first (canonical list)
  for (const [name, agent] of Object.entries(agents)) {
    const session = sessionByName[name]
    // For agents without a registry session, synthesize one from agents.json for liveness check
    const effectiveSession = session || { tmux_session: "openfleet", tmux_window: name }
    const alive = isAlive(effectiveSession)
    const role = agent.role || session?.role || "ephemeral"
    const status = alive ? "🟢 alive" : role === "persistent" || role === "orchestrator" ? "⚫ dormant" : "💀 dead"
    console.log(
      name.padEnd(20),
      (agent.harness || session?.harness || "?").padEnd(12),
      (agent.model || session?.model || "?").padEnd(15),
      role.padEnd(12),
      status,
    )
    delete sessionByName[name] // don't show twice
  }

  // Show any sessions not in agents.json (ad-hoc spawns)
  for (const [name, session] of Object.entries(sessionByName)) {
    const alive = isAlive(session)
    const status = alive ? "🟢 alive" : "💀 dead"
    console.log(
      name.padEnd(20),
      (session.harness || "?").padEnd(12),
      (session.model || "?").padEnd(15),
      (session.role || "ephemeral").padEnd(12),
      status,
      "(unregistered)",
    )
  }
}

function isAlive(session) {
  // Primary check: does the agent have a live tmux window?
  if (session.tmux_session && session.tmux_window) {
    try {
      execFileSync("tmux", ["has-session", "-t", session.tmux_session], { stdio: "ignore" })
      const wins = execFileSync("tmux", ["list-windows", "-t", session.tmux_session, "-F", "#{window_name}"], { encoding: "utf8" })
      if (wins.split("\n").includes(session.tmux_window)) return true
    } catch {}
  }

  return false
}

try {
  main()
} catch (e) {
  console.error(e.message)
  process.exit(1)
}
