#!/usr/bin/env node

const os = require("os")
const path = require("path")
const { parseArgs } = require("../lib/opencode")
const { createEventStore } = require("../core/runtime/events")
const { getJob, updateJob } = require("../core/runtime/jobs")
const { getTask, updateTask } = require("../core/runtime/tasks")

function main() {
  const args = parseArgs(process.argv.slice(2))
  const jobId = args.job || args._[0]
  if (!jobId) throw new Error("Usage: report-completion <job-id> [--status completed] [--summary ...] [--output '{...}']")

  const stateRoot = args["state-root"] || process.env.OPENFLEET_CANONICAL_STATE_DIR || path.join(os.homedir(), ".openfleet")
  const eventStore = createEventStore(stateRoot)
  const job = getJob(stateRoot, jobId)
  if (!job) throw new Error(`Unknown job: ${jobId}`)

  const outputPatch = parseJson(args.output) || {}
  if (args.summary) outputPatch.summary = args.summary

  const completed = updateJob(stateRoot, jobId, {
    status: args.status || "completed",
    output: {
      ...(job.output || {}),
      ...outputPatch,
    },
    completed_at: new Date().toISOString(),
  })

  eventStore.append({ type: "job.completed", agent_id: completed.agent || "system", payload: completed })

  const taskId = args.task || job.input?.task_id || job.input?.context?.task_id || null
  let task = null
  if (taskId) {
    const currentTask = getTask(stateRoot, taskId)
    if (currentTask) {
      task = updateTask(stateRoot, taskId, { status: 'completed', blocked_on: null })
      eventStore.append({ type: 'task.updated', agent_id: task.assignee || 'openfleet', payload: task })
    }
  }

  return print({ job: completed, task })
}

function parseJson(value) {
  if (!value) return null
  return JSON.parse(value)
}

function print(value) {
  process.stdout.write(`${JSON.stringify(value, null, 2)}\n`)
}

try {
  main()
} catch (error) {
  console.error(error.message)
  process.exit(1)
}
