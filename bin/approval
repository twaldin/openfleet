#!/usr/bin/env node

const os = require("os")
const path = require("path")
const { parseArgs } = require("../lib/opencode")
const { createEventStore } = require("../core/runtime/events")
const { createApproval, getApproval, listApprovals, updateApproval } = require("../core/runtime/approvals")

function main() {
  const args = parseArgs(process.argv.slice(2))
  const [command, id] = args._
  const stateRoot = args["state-root"] || process.env.OPENFLEET_CANONICAL_STATE_DIR || path.join(os.homedir(), ".openfleet")
  const eventStore = createEventStore(stateRoot)
  if (command === "create") {
    const approval = createApproval(stateRoot, {
      task_id: args.task,
      job_id: args.job,
      workflow_id: args.workflow,
      agent_id: args.agent,
      action_type: args.action,
      summary: args.summary,
      risk_class: args.risk,
      channel_binding: args.channel,
    })
    eventStore.append({ type: "approval.created", agent_id: approval.agent_id || "openfleet", payload: approval })
    return print(approval)
  }
  if (command === "update") {
    const approval = updateApproval(stateRoot, id, {
      status: args.status,
      resolved_by: args.by || undefined,
      resolution: args.resolution || undefined,
      resolved_at: args.status && args.status !== 'pending' ? new Date().toISOString() : undefined,
    })
    eventStore.append({ type: "approval.updated", agent_id: approval.agent_id || "openfleet", payload: approval })
    return print(approval)
  }
  if (command === "show") return print(getApproval(stateRoot, id))
  if (command === "list") return print(listApprovals(stateRoot))
  throw new Error("Usage: approval <create|update|show|list>")
}

function print(v) { process.stdout.write(`${JSON.stringify(v, null, 2)}\n`) }
try { main() } catch (e) { console.error(e.message); process.exit(1) }
