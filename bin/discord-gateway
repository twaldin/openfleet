#!/usr/bin/env node
/**
 * OpenFleet Discord Gateway
 *
 * Real-time Discord bot that bridges Discord and the agent fleet.
 * Ported from claudecord's MCP server — same architecture, harness-agnostic.
 *
 * Inbound:  Discord messages → resolve channel → bin/send to agent (tmux/opencode/codex)
 * Outbound: MCP tools (openfleet_reply, openfleet_fetch_messages) or HTTP side-channel
 *
 * Install on the orchestrator session. Agents use bin/remote discord post for outbound.
 */
const { Server } = require("@modelcontextprotocol/sdk/server/index.js")
const { StdioServerTransport } = require("@modelcontextprotocol/sdk/server/stdio.js")
const { ListToolsRequestSchema, CallToolRequestSchema } = require("@modelcontextprotocol/sdk/types.js")
const {
  Client,
  GatewayIntentBits,
  Partials,
  ChannelType,
  EmbedBuilder,
} = require("discord.js")
const { execFile, execFileSync, execSync } = require("child_process")
const { readFileSync, writeFileSync, existsSync, mkdirSync } = require("fs")
const { createServer } = require("http")
const os = require("os")
const path = require("path")
const crypto = require("crypto")
const { getAgent } = require("../core/runtime/agents")
const { loadSessionMetadata } = require("../core/runtime/session")
const {
  approveViaKeys,
  buildEscalationMessage,
  denyViaKeys,
  evaluateSafety,
  parsePermissionPrompt,
} = require("../core/permission-resolver")

// ---- Config ----------------------------------------------------------------

const STATE_ROOT = process.env.OPENFLEET_CANONICAL_STATE_DIR || path.join(os.homedir(), ".openfleet")
const CONFIG_PATH = path.join(STATE_ROOT, "discord.json")
const SEND_BIN = path.resolve(__dirname, "send")
const REMOTE_BIN = path.resolve(__dirname, "remote")
const ATTACHMENT_DIR = path.join(STATE_ROOT, "attachments")

let config
try {
  config = JSON.parse(readFileSync(CONFIG_PATH, "utf8"))
} catch {
  process.stderr.write(`openfleet-gateway: cannot read ${CONFIG_PATH}\n`)
  process.exit(1)
}

const TOKEN = config.token
const GUILD_ID = config.guild_id
const HTTP_PORT = parseInt(process.env.OPENFLEET_GATEWAY_PORT || "19532", 10)
const ALLOWED_USERS = (process.env.OPENFLEET_ALLOWED_USERS || "").split(",").filter(Boolean)
const TMUX_SESSION = process.env.OPENFLEET_TMUX_SESSION || "openfleet"

if (!TOKEN) {
  process.stderr.write("openfleet-gateway: no token in discord.json\n")
  process.exit(1)
}

// Reverse map: channelId → channelName
const channelIdToName = {}
for (const [name, id] of Object.entries(config.channels || {})) {
  channelIdToName[id] = name
}

// Load deployment routing if available
let deploymentRouting = {}
const deploymentPath = process.env.OPENFLEET_DEPLOYMENT
try {
  const dep = JSON.parse(readFileSync(deploymentPath, "utf8"))
  deploymentRouting = dep.routing || {}
} catch {}

// ---- Channel helpers -------------------------------------------------------

// Map agent names to their Discord channel IDs (from deployment routing)
const agentToChannelId = {}
for (const [agent, binding] of Object.entries(deploymentRouting.persistent_agent_channels || {})) {
  const channelName = binding.replace("channel://", "")
  if (config.channels?.[channelName]) {
    agentToChannelId[agent] = config.channels[channelName]
  }
}

function agentChannelMention(agentName) {
  const id = agentToChannelId[agentName]
  return id ? ` <#${id}>` : ""
}

// ---- Agent routing ---------------------------------------------------------

function resolveAgentForChannel(channelId) {
  const channelName = channelIdToName[channelId]
  if (!channelName) return null

  // Check persistent_agent_channels from deployment config
  const pac = deploymentRouting.persistent_agent_channels || {}
  for (const [agent, binding] of Object.entries(pac)) {
    const boundName = binding.replace("channel://", "")
    if (boundName === channelName) return agent
  }

  return null
}

// ---- Discord client --------------------------------------------------------

const client = new Client({
  intents: [
    GatewayIntentBits.Guilds,
    GatewayIntentBits.GuildMessages,
    GatewayIntentBits.MessageContent,
    GatewayIntentBits.GuildMessageReactions,
  ],
  partials: [Partials.Message, Partials.Reaction],
})

const DISCORD_MAX = 2000

function chunkText(text) {
  if (text.length <= DISCORD_MAX) return [text]
  const out = []
  let rest = text
  while (rest.length > DISCORD_MAX) {
    const slice = rest.slice(0, DISCORD_MAX)
    const cut = slice.lastIndexOf("\n")
    const at = cut > DISCORD_MAX / 2 ? cut : DISCORD_MAX
    out.push(rest.slice(0, at))
    rest = rest.slice(at).replace(/^\n/, "")
  }
  if (rest) out.push(rest)
  return out
}

async function sendToChannel(channelId, text, replyTo) {
  const ch = await client.channels.fetch(channelId)
  if (!ch || !ch.isTextBased()) throw new Error(`channel ${channelId} not text-based`)
  const chunks = chunkText(text)
  const ids = []
  for (let i = 0; i < chunks.length; i++) {
    const opts = { content: chunks[i] }
    if (i === 0 && replyTo) {
      opts.reply = { messageReference: replyTo, failIfNotExists: false }
    }
    const sent = await ch.send(opts)
    ids.push(sent.id)
  }
  return ids
}

// ---- Agent message delivery ------------------------------------------------

function formatDiscordMessage(channelName, author, content, attachmentPaths) {
  const IMAGE_EXTS = new Set(["png", "jpg", "jpeg", "gif", "webp", "bmp", "svg"])
  const parts = []
  if (content) parts.push(content)
  if (attachmentPaths) {
    for (const p of attachmentPaths) {
      const ext = p.split(".").pop().toLowerCase()
      const label = IMAGE_EXTS.has(ext) ? "Image" : "File"
      parts.push(`[${label}: ${p}]`)
    }
  }
  const body = parts.join("\n") || "(empty)"
  return `[${author}]: ${body}\n(Reply via: openfleet post "<your reply>")`
}

function sendToAgent(agentName, msg) {
  const channelName = channelIdToName[msg.channelId] || msg.channelId
  const author = msg.author.username

  const sendFormatted = (attachmentPaths) => {
    const formatted = formatDiscordMessage(channelName, author, msg.content, attachmentPaths)
    execFile("node", [SEND_BIN, agentName, formatted], (err) => {
      if (err) {
        process.stderr.write(`openfleet-gateway: send to ${agentName} failed, routing to parent\n`)
        execFile("node", [SEND_BIN, "--to-parent", "--sender", "discord", "--message", formatted], (err2) => {
          if (err2) process.stderr.write(`openfleet-gateway: send to parent also failed: ${err2.message}\n`)
        })
      }
    })
  }

  if (msg.attachments.size > 0) {
    downloadAttachments(msg).then(paths => sendFormatted(paths))
  } else {
    sendFormatted(null)
  }
}

async function downloadAttachments(msg) {
  mkdirSync(ATTACHMENT_DIR, { recursive: true })
  const paths = []
  for (const [, att] of msg.attachments) {
    const ext = att.name?.split(".").pop() || "bin"
    const filename = `${msg.id}-${att.id}.${ext}`
    const filepath = path.join(ATTACHMENT_DIR, filename)
    try {
      // Use curl for reliable download — fetch can have issues with Discord CDN
      execFileSync("curl", ["-sS", "-L", "-o", filepath, "--max-time", "15", att.url], { stdio: "pipe" })
      const stat = require("fs").statSync(filepath)
      if (stat.size > 0) {
        paths.push(filepath)
        process.stderr.write(`openfleet-gateway: saved attachment ${filepath} (${stat.size} bytes)\n`)
      } else {
        process.stderr.write(`openfleet-gateway: attachment empty, trying proxyURL\n`)
        execFileSync("curl", ["-sS", "-L", "-o", filepath, "--max-time", "15", att.proxyURL || att.url], { stdio: "pipe" })
        paths.push(filepath)
      }
    } catch (err) {
      process.stderr.write(`openfleet-gateway: attachment download failed: ${err.message}\n`)
    }
  }
  return paths
}

// ---- Permission watcher ----------------------------------------------------

const POLL_INTERVAL = 3000
const PERMISSION_TIMEOUT = 5 * 60 * 1000
const pendingPrompts = new Map()
const promptByMessageId = new Map()
const resolvedHashes = new Map()

function paneHash(text) {
  return crypto.createHash("sha1").update(text.slice(-500)).digest("hex").slice(0, 12)
}

function expandHome(value) {
  if (!value) return value
  if (value === "~") return os.homedir()
  if (value.startsWith("~/")) return path.join(os.homedir(), value.slice(2))
  return value
}

function resolveAgentWorkdir(agentName) {
  const session = loadSessionMetadata(STATE_ROOT, agentName)
  const agent = getAgent(STATE_ROOT, agentName)
  return expandHome(session?.directory || agent?.directory || null)
}

async function pollPermissions() {
  const now = Date.now()

  // Handle timeouts
  for (const [name, pending] of pendingPrompts) {
    if (now - pending.detectedAt > PERMISSION_TIMEOUT) {
      pendingPrompts.delete(name)
      promptByMessageId.delete(pending.messageId)
      resolvedHashes.set(pending.paneHash, now)
      // Auto-deny
      try {
        denyViaKeys(TMUX_SESSION, name, pending.denySequence)
      } catch {}
      try {
        const ch = await client.channels.fetch(pending.channelId)
        const msg = await ch.messages.fetch(pending.messageId)
        const embed = new EmbedBuilder()
          .setTitle(`Permission timed out — ${name}`)
          .setColor(0x95A5A6)
          .setDescription(buildEscalationMessage(name, pending.path))
          .addFields({ name: "Prompt type", value: pending.patternId, inline: true }, { name: "Result", value: "AUTO-DENIED (5m)", inline: true })
        await msg.edit({ embeds: [embed] })
      } catch {}
    }
  }

  // Clean old resolved hashes
  for (const [h, ts] of resolvedHashes) {
    if (now - ts > 60000) resolvedHashes.delete(h)
  }

  // Scan tmux windows for permission prompts (use index:name to avoid dot-parsing issues)
  let windowEntries
  try {
    windowEntries = execSync(`tmux list-windows -t ${TMUX_SESSION} -F '#{window_index}\t#{window_name}'`, { encoding: "utf8" })
      .trim().split("\n").filter(Boolean).map(line => {
        const [idx, name] = line.split("\t")
        return { index: idx, name }
      })
  } catch { return }

  // Skip infrastructure windows, the orchestrator, and agents with bypass-permissions
  const SKIP_WINDOWS = new Set(["gateway", "cron", "dashboard", "bridge", "capture"])
  // Also skip the orchestrator — permission prompts there are interactive UI, not unattended agents
  const orchestratorWindow = (() => {
    try {
      const orch = JSON.parse(require("fs").readFileSync(path.join(STATE_ROOT, "orchestrator.json"), "utf8"))
      return orch.tmux_window || null
    } catch { return null }
  })()
  if (orchestratorWindow) SKIP_WINDOWS.add(orchestratorWindow)

  for (const { index: winIndex, name: windowName } of windowEntries) {
    if (pendingPrompts.has(windowName)) continue
    if (SKIP_WINDOWS.has(windowName)) continue

    let paneText
    try {
      // Use window index to avoid tmux target parsing issues with dots in names
      paneText = execSync(`tmux capture-pane -t ${TMUX_SESSION}:${winIndex} -p -S -30`, { encoding: "utf8" })
    } catch { continue }

    const clean = paneText.replace(/\x1b\[[0-9;]*[mGKHFJABCDsuhlr]/g, "")

    // Skip agents running with bypass-permissions or full-auto — they never have real prompts
    // and their output (e.g. "/P2/P3" position refs, "//" paths) triggers false positives
    if (/bypass permissions on|full-auto|dangerously/i.test(clean)) continue

    const parsed = parsePermissionPrompt(clean, { agent: windowName })
    if (!parsed) continue

    const hash = paneHash(clean)
    if (resolvedHashes.has(hash)) continue

    const agentWorkdir = resolveAgentWorkdir(windowName)
    const safety = evaluateSafety(parsed.request || parsed.path, agentWorkdir)
    if (safety === "safe") {
      try {
        approveViaKeys(TMUX_SESSION, windowName, parsed.approveSequence)
        resolvedHashes.set(hash, now)
        process.stderr.write(`openfleet-gateway: auto-approved safe permission prompt for ${windowName}: ${parsed.path}\n`)
        continue
      } catch (err) {
        process.stderr.write(`openfleet-gateway: safe auto-approve failed for ${windowName}: ${err.message}\n`)
      }
    }

    // Cascade: try orchestrator first, escalate to Discord if orchestrator can't resolve
    try {
      const msg = `[PERMISSION] Agent '${windowName}' needs permission to access: ${parsed.path || "(unknown)"}. Safety: risky. Approve via tmux send-keys or escalate to Discord #alerts.`
      execFile("node", [SEND_BIN, "--to-parent", "--sender", "permission-resolver", "--message", msg], { timeout: 10000 }, () => {})
      process.stderr.write(`openfleet-gateway: escalated risky permission to orchestrator for ${windowName}: ${parsed.path}\n`)
    } catch {}

    const channelId = config.channels?.["alerts"] || agentToChannelId[windowName] || config.channels?.[windowName]
    if (!channelId) continue

    try {
      const ch = await client.channels.fetch(channelId)
      const embed = new EmbedBuilder()
        .setTitle(`Permission required — ${windowName}`)
        .setColor(0xFFA500)
        .setDescription(buildEscalationMessage(windowName, parsed.path))
        .addFields(
          { name: "Prompt type", value: parsed.patternId, inline: true },
          { name: "Requested path", value: (parsed.path || "(unknown)").slice(0, 1024), inline: false },
          { name: "Agent workdir", value: (agentWorkdir || "(unknown)").slice(0, 1024), inline: false },
        )
        .setFooter({ text: "React ✅ to allow | ❌ to deny | Auto-denies in 5m" })
        .setTimestamp()
      const sentMsg = await ch.send({ embeds: [embed] })
      await sentMsg.react("✅")
      await sentMsg.react("❌")

      const pending = {
        agentName: windowName, channelId, messageId: sentMsg.id,
        paneHash: hash, detectedAt: now, patternId: parsed.patternId, path: parsed.path,
        approveSequence: parsed.approveSequence, denySequence: parsed.denySequence,
      }
      pendingPrompts.set(windowName, pending)
      promptByMessageId.set(sentMsg.id, windowName)
      process.stderr.write(`openfleet-gateway: permission prompt posted for ${windowName}\n`)
    } catch (err) {
      process.stderr.write(`openfleet-gateway: failed to post permission prompt: ${err}\n`)
    }
  }
}

// ---- MCP server ------------------------------------------------------------

const mcp = new Server(
  { name: "openfleet-discord", version: "1.0.0" },
  {
    capabilities: { tools: {} },
    instructions: [
      "OpenFleet Discord gateway. Routes messages between Discord and your agent fleet.",
      "",
      "Use openfleet_reply to send messages to Discord channels.",
      "Use openfleet_fetch_messages to read channel history.",
      "Use openfleet_create_channel to create agent channels on spawn.",
      "Use openfleet_archive_channel to archive channels when agents complete.",
    ].join("\n"),
  },
)

mcp.setRequestHandler(ListToolsRequestSchema, async () => ({
  tools: [
    {
      name: "openfleet_reply",
      description: "Send a message to a Discord channel. Auto-splits at 2000 chars.",
      inputSchema: {
        type: "object",
        properties: {
          channel_id: { type: "string", description: "Discord channel ID" },
          text: { type: "string", description: "Message text" },
          reply_to: { type: "string", description: "Message ID to reply to (optional)" },
        },
        required: ["channel_id", "text"],
      },
    },
    {
      name: "openfleet_fetch_messages",
      description: "Fetch recent messages from a Discord channel.",
      inputSchema: {
        type: "object",
        properties: {
          channel_id: { type: "string", description: "Discord channel ID" },
          limit: { type: "number", description: "Max messages (default 20, max 100)" },
        },
        required: ["channel_id"],
      },
    },
    {
      name: "openfleet_create_channel",
      description: "Create a Discord channel for a spawned agent.",
      inputSchema: {
        type: "object",
        properties: {
          agent_name: { type: "string" },
          agent_type: { type: "string", enum: ["coder", "researcher", "evaluator", "persistent", "monitor"] },
          task: { type: "string", description: "Task description for spawn embed" },
          model: { type: "string", description: "Model name for embed" },
        },
        required: ["agent_name"],
      },
    },
    {
      name: "openfleet_create_thread",
      description: "Create a thread in a channel for an ephemeral agent task. Use for coders/evaluators so each task gets isolated discussion.",
      inputSchema: {
        type: "object",
        properties: {
          channel_id: { type: "string", description: "Parent channel ID (e.g. #code-status)" },
          agent_name: { type: "string" },
          task: { type: "string", description: "Task title (becomes thread name)" },
          model: { type: "string" },
        },
        required: ["channel_id", "agent_name"],
      },
    },
    {
      name: "openfleet_archive_channel",
      description: "Archive a Discord channel when an agent completes.",
      inputSchema: {
        type: "object",
        properties: {
          channel_id: { type: "string" },
          agent_name: { type: "string" },
          pr_number: { type: "number" },
          duration: { type: "string" },
        },
        required: ["channel_id", "agent_name"],
      },
    },
  ],
}))

mcp.setRequestHandler(CallToolRequestSchema, async (req) => {
  const args = req.params.arguments || {}
  try {
    switch (req.params.name) {
      case "openfleet_reply": {
        const ids = await sendToChannel(args.channel_id, args.text, args.reply_to)
        return { content: [{ type: "text", text: ids.length === 1 ? `sent (id: ${ids[0]})` : `sent ${ids.length} parts` }] }
      }

      case "openfleet_fetch_messages": {
        const ch = await client.channels.fetch(args.channel_id)
        const limit = Math.min(args.limit || 20, 100)
        const msgs = await ch.messages.fetch({ limit })
        const me = client.user?.id
        const arr = [...msgs.values()].reverse()
        const out = arr.length === 0
          ? "(no messages)"
          : arr.map(m => {
              const who = m.author.id === me ? "me" : m.author.username
              const atts = m.attachments.size > 0 ? ` +${m.attachments.size}att` : ""
              return `[${m.createdAt.toISOString()}] ${who}: ${m.content.replace(/[\r\n]+/g, " ⏎ ")}  (id: ${m.id}${atts})`
            }).join("\n")
        return { content: [{ type: "text", text: out }] }
      }

      case "openfleet_create_channel": {
        if (!GUILD_ID) throw new Error("No guild_id in discord.json")
        const guild = client.guilds.cache.get(GUILD_ID)
        if (!guild) throw new Error(`Guild ${GUILD_ID} not in cache`)

        const agentName = args.agent_name
        const agentType = args.agent_type || "coder"
        const task = args.task || ""

        const categoryNames = { coder: "Coders", researcher: "Research", evaluator: "Reviews", persistent: "Agents", monitor: "Agents" }
        const categoryName = categoryNames[agentType] || "Agents"
        let parentId
        const existing = guild.channels.cache.find(c => c.name === categoryName && c.type === ChannelType.GuildCategory)
        if (existing) {
          parentId = existing.id
        } else {
          const created = await guild.channels.create({ name: categoryName, type: ChannelType.GuildCategory })
          parentId = created.id
        }

        const channel = await guild.channels.create({
          name: agentName, type: ChannelType.GuildText, parent: parentId, topic: task || undefined,
        })

        const AGENT_COLORS = { coder: 0x5865F2, researcher: 0xED7D31, evaluator: 0xED4245, persistent: 0x57F287, monitor: 0x57F287 }
        const embed = new EmbedBuilder()
          .setTitle(`${agentName} spawned`)
          .setColor(AGENT_COLORS[agentType] || 0x5865F2)
          .addFields(
            { name: "Type", value: agentType, inline: true },
            { name: "Task", value: task || "(none)", inline: false },
          )
        if (args.model) embed.addFields({ name: "Model", value: args.model, inline: true })
        embed.setTimestamp()

        await channel.send({ embeds: [embed] })

        // Update discord.json with new channel
        config.channels[agentName] = channel.id
        channelIdToName[channel.id] = agentName
        writeFileSync(CONFIG_PATH, JSON.stringify(config, null, 2))

        return { content: [{ type: "text", text: `created channel ${channel.id} (#${agentName})` }] }
      }

      case "openfleet_create_thread": {
        const parentCh = await client.channels.fetch(args.channel_id)
        const threadName = args.task ? `${args.agent_name}: ${args.task}`.slice(0, 100) : args.agent_name
        const thread = await parentCh.threads.create({
          name: threadName,
          autoArchiveDuration: 1440, // 24 hours
          reason: `OpenFleet agent: ${args.agent_name}`,
        })

        const AGENT_COLORS = { coder: 0x5865F2, researcher: 0xED7D31, evaluator: 0xED4245, persistent: 0x57F287, monitor: 0x57F287 }
        const embed = new EmbedBuilder()
          .setTitle(`${args.agent_name} started`)
          .setColor(AGENT_COLORS[args.agent_type] || 0x5865F2)
          .addFields({ name: "Task", value: args.task || "(none)", inline: false })
        if (args.model) embed.addFields({ name: "Model", value: args.model, inline: true })
        embed.setTimestamp()
        await thread.send({ embeds: [embed] })

        // Register thread as agent's channel for routing
        config.channels[args.agent_name] = thread.id
        channelIdToName[thread.id] = args.agent_name
        agentToChannelId[args.agent_name] = thread.id
        writeFileSync(CONFIG_PATH, JSON.stringify(config, null, 2))

        return { content: [{ type: "text", text: `created thread ${thread.id} (${threadName}) in <#${args.channel_id}>` }] }
      }

      case "openfleet_archive_channel": {
        const ch = await client.channels.fetch(args.channel_id)
        if (GUILD_ID) {
          await ch.permissionOverwrites.edit(GUILD_ID, { SendMessages: false })
        }
        const embed = new EmbedBuilder()
          .setTitle(`${args.agent_name} completed`)
          .setColor(0x95A5A6)
          .setDescription("Task finished. Channel archived.")
        if (args.duration) embed.addFields({ name: "Duration", value: args.duration, inline: true })
        if (args.pr_number) embed.addFields({ name: "PR", value: `#${args.pr_number}`, inline: true })
        embed.setFooter({ text: "React 📦 Archive | 🗑️ Delete" })
        const msg = await ch.send({ embeds: [embed] })
        await msg.react("📦")
        await msg.react("🗑️")

        // Remove from discord.json channel map
        const name = channelIdToName[args.channel_id]
        if (name) {
          delete config.channels[name]
          delete channelIdToName[args.channel_id]
          writeFileSync(CONFIG_PATH, JSON.stringify(config, null, 2))
        }

        return { content: [{ type: "text", text: `archived channel ${args.channel_id}` }] }
      }

      default:
        return { content: [{ type: "text", text: `unknown tool: ${req.params.name}` }], isError: true }
    }
  } catch (err) {
    return { content: [{ type: "text", text: `${req.params.name} failed: ${err.message}` }], isError: true }
  }
})

// ---- HTTP side-channel for agents ------------------------------------------

const httpServer = createServer(async (req, res) => {
  const json = (status, body) => {
    const payload = JSON.stringify(body)
    res.writeHead(status, { "Content-Type": "application/json" })
    res.end(payload)
  }

  if (req.method === "GET" && req.url === "/health") {
    return json(200, { status: "ok", uptime: process.uptime() })
  }

  if (req.method === "POST" && req.url === "/reply") {
    const chunks = []
    req.on("data", c => chunks.push(c))
    req.on("end", async () => {
      try {
        const body = JSON.parse(Buffer.concat(chunks).toString("utf8"))
        if (!body.channelId || !body.text) return json(400, { error: "channelId and text required" })
        await sendToChannel(body.channelId, body.text, body.replyTo)
        json(200, { ok: true })
      } catch (err) {
        json(500, { error: err.message })
      }
    })
    return
  }

  json(404, { error: "not found" })
})

// ---- Inbound message handling ----------------------------------------------

client.on("messageCreate", (msg) => {
  if (msg.author.bot) return
  if (ALLOWED_USERS.length > 0 && !ALLOWED_USERS.includes(msg.author.id)) return

  const channelId = msg.channelId
  const channelName = channelIdToName[channelId]
  const agentName = resolveAgentForChannel(channelId)

  process.stderr.write(`openfleet-gateway: message in #${channelName || channelId} → ${agentName || "parent"}\n`)

  const ack = () => { msg.react("👀").catch(() => {}) }

  if (agentName) {
    sendToAgent(agentName, msg)
    ack()
  } else {
    // Route to orchestrator/parent — handle attachments same as agent path
    const author = msg.author.username
    const prefix = `[${author}]: `

    if (msg.attachments.size > 0) {
      downloadAttachments(msg).then(paths => {
        const IMAGE_EXTS = new Set(["png", "jpg", "jpeg", "gif", "webp", "bmp", "svg"])
        const parts = []
        if (msg.content) parts.push(msg.content)
        for (const p of paths) {
          const ext = p.split(".").pop().toLowerCase()
          const label = IMAGE_EXTS.has(ext) ? "Image" : "File"
          parts.push(`[${label}: ${p}]`)
        }
        const formatted = prefix + (parts.join("\n") || "(attachment)")
        execFile("node", [SEND_BIN, "--to-parent", "--sender", "discord", "--message", formatted], (err) => {
          if (err) { msg.react("❌").catch(() => {}); process.stderr.write(`openfleet-gateway: send to parent failed: ${err.message}\n`) }
          else ack()
        })
      })
    } else {
      const formatted = prefix + (msg.content || "(empty)")
      execFile("node", [SEND_BIN, "--to-parent", "--sender", "discord", "--message", formatted], (err) => {
        if (err) { msg.react("❌").catch(() => {}); process.stderr.write(`openfleet-gateway: send to parent failed: ${err.message}\n`) }
        else ack()
      })
    }
  }
})

client.on("error", (err) => {
  process.stderr.write(`openfleet-gateway: discord error: ${err}\n`)
})

// ---- Reaction handler for permissions --------------------------------------

client.on("messageReactionAdd", async (reaction, user) => {
  if (reaction.partial) { try { await reaction.fetch() } catch { return } }
  if (user.bot) return
  if (ALLOWED_USERS.length > 0 && !ALLOWED_USERS.includes(user.id)) return

  const agentName = promptByMessageId.get(reaction.message.id)
  if (!agentName) return
  const pending = pendingPrompts.get(agentName)
  if (!pending) return

  const emoji = reaction.emoji.name
  const decision = emoji === "✅" ? "allow" : emoji === "❌" ? "deny" : null
  if (!decision) return

  pendingPrompts.delete(agentName)
  promptByMessageId.delete(pending.messageId)
  resolvedHashes.set(pending.paneHash, Date.now())

  if (decision === "allow") {
    try { approveViaKeys(TMUX_SESSION, agentName, pending.approveSequence) } catch {}
  } else {
    try { denyViaKeys(TMUX_SESSION, agentName, pending.denySequence) } catch {}
  }

  try {
    const ch = await client.channels.fetch(pending.channelId)
    const sentMsg = await ch.messages.fetch(pending.messageId)
    const embed = new EmbedBuilder()
      .setTitle(`Permission ${decision === "allow" ? "allowed" : "denied"} — ${agentName}`)
      .setColor(decision === "allow" ? 0x57F287 : 0xED4245)
      .setDescription(buildEscalationMessage(agentName, pending.path))
      .addFields({ name: "Prompt type", value: pending.patternId, inline: true }, { name: "Decision", value: decision.toUpperCase(), inline: true })
      .setTimestamp()
    await sentMsg.edit({ embeds: [embed] })
  } catch {}
})

// ---- Status board (persistent embed, edits in place) ----------------------

const STATUS_BOARD_FILE = path.join(STATE_ROOT, "status-board.json")
const STATUS_CHANNEL = config.channels?.["fleet-status"]
const STATUS_INTERVAL = 60_000 // update every 60s

function loadStatusBoard() {
  try { return JSON.parse(readFileSync(STATUS_BOARD_FILE, "utf8")) } catch { return {} }
}

function saveStatusBoard(data) {
  writeFileSync(STATUS_BOARD_FILE, JSON.stringify(data, null, 2))
}

function buildStatusEmbed() {
  const agents = getFleetStatus()
  const alive = agents.filter(a => a.status === "working" || a.status === "idle")
  const dormant = agents.filter(a => a.status === "dormant")

  let taskCount = 0, blockerCount = 0, activeTasks = []
  try {
    const tasks = JSON.parse(readFileSync(path.join(STATE_ROOT, "tasks.json"), "utf8"))
    const all = tasks.tasks ? Object.values(tasks.tasks) : Object.values(tasks)
    activeTasks = all.filter(t => t.status !== "completed" && t.status !== "archived")
    taskCount = activeTasks.length
  } catch {}
  try {
    const blockers = JSON.parse(readFileSync(path.join(STATE_ROOT, "blockers.json"), "utf8"))
    const all = blockers.blockers ? Object.values(blockers.blockers) : Object.values(blockers)
    blockerCount = all.filter(b => b.status === "open").length
  } catch {}

  let orch = {}
  try { orch = JSON.parse(readFileSync(path.join(STATE_ROOT, "orchestrator.json"), "utf8")) } catch {}

  const color = blockerCount > 0 ? 0xFEE75C : alive.length > 0 ? 0x57F287 : 0x95A5A6
  const embed = new EmbedBuilder()
    .setTitle("OpenFleet — System Status")
    .setColor(color)
    .setDescription(`Updated <t:${Math.floor(Date.now() / 1000)}:R>`)

  // Orchestrator
  const orchName = orch.agent || "orchestrator"
  const orchChannel = agentChannelMention(orchName)
  embed.addFields({
    name: "Orchestrator",
    value: `🟢 **${orchName}**${orchChannel} — ${orch.harness || "?"}/${orch.model || "?"}`,
    inline: false,
  })

  // Live agents (only show alive ones)
  if (alive.length > 0) {
    const lines = alive.map(a => {
      const icon = a.status === "working" ? "🔵" : "🟢"
      const ch = agentChannelMention(a.name)
      const task = a.currentTask ? ` — *${a.currentTask.slice(0, 40)}*` : ""
      return `${icon} **${a.name}**${ch} — ${a.harness}/${a.model}${task}`
    })
    embed.addFields({ name: `Active Agents (${alive.length})`, value: lines.join("\n"), inline: false })
  }

  // Dormant agents (have sessions but not running)
  if (dormant.length > 0) {
    const lines = dormant.slice(0, 8).map(a => {
      const ch = agentChannelMention(a.name)
      return `⚫ **${a.name}**${ch} — ${a.harness}/${a.model}`
    })
    embed.addFields({ name: `Dormant (${dormant.length})`, value: lines.join("\n"), inline: false })
  }

  // Summary row
  embed.addFields(
    { name: "Tasks", value: String(taskCount), inline: true },
    { name: "Blockers", value: String(blockerCount), inline: true },
    { name: "Gateway", value: "🟢 Online", inline: true },
  )

  // Cron schedule
  const cronLines = [
    "⏰ `07:27` Morning briefing → #daily",
    "⏰ `07-22:17` Heartbeat (hourly)",
    "⏰ `09:25 M-F` Spawn stock-monitor",
    "⏰ `16:05 M-F` Kill stock-monitor",
    "⏰ `09:30 M-F` Trader market scan",
    "⏰ `2h` Monitor VPS health check",
    "⏰ `21:03` Habit nudge",
    "⏰ `00:02` Nightly reflection + compaction",
    "⏰ `05:42` Overnight news digest",
    "⏰ `20:00 Sun` Weekly review",
  ]
  embed.addFields({ name: "Scheduled", value: cronLines.join("\n"), inline: false })

  embed.setFooter({ text: "Auto-updates every 60s • Dead agents hidden" })
  embed.setTimestamp()
  return embed
}

function getFleetStatus() {
  // Build deduplicated agent list with real liveness checks
  let reg = { sessions: {} }
  try { reg = JSON.parse(readFileSync(path.join(STATE_ROOT, "registry.json"), "utf8")) } catch {}

  // Deduplicate by name (keep newest)
  const byName = new Map()
  for (const s of Object.values(reg.sessions || {})) {
    if (!s.name) continue
    const existing = byName.get(s.name)
    if (!existing || (s.created_at || 0) > (existing.created_at || 0)) {
      byName.set(s.name, s)
    }
  }

  // Check liveness for each
  const liveWindows = getTmuxWindows()
  const agents = []

  for (const [name, session] of byName) {
    const agent = {
      name,
      harness: session.harness || "opencode",
      model: session.model || "?",
      status: "dead",
      currentTask: null,
    }

    // Check tmux window exists (works for claude-code, codex, and tmux-visible opencode)
    if (session.tmux_session && session.tmux_window && liveWindows.has(`${session.tmux_session}:${session.tmux_window}`)) {
      agent.status = "idle" // alive, can receive messages
    }

    // Check opencode session — only if recently active (within 15 min)
    // The opencode API reports stale sessions as existing, so we gate on updated_at
    if (agent.status === "dead" && session.session_id && !session.tmux_window) {
      const age = Date.now() - new Date(session.updated_at || 0).getTime()
      if (age < 15 * 60 * 1000 && checkOpencodeSession(session.session_id)) {
        agent.status = "idle"
      }
    }

    // Check if agent has an active job (working vs idle)
    if (agent.status === "idle") {
      const activeJob = getActiveJob(name)
      if (activeJob) {
        agent.status = "working"
        agent.currentTask = activeJob.type || activeJob.title || "task"
      }
    }

    // If truly dead, check if it has a recent session (dormant = has state but no live session)
    if (agent.status === "dead") {
      const age = Date.now() - new Date(session.updated_at || session.created_at || 0).getTime()
      if (age < 24 * 60 * 60 * 1000) {
        agent.status = "dormant"
      }
    }

    if (agent.status !== "dead") {
      agents.push(agent)
    }
  }

  return agents
}

function getTmuxWindows() {
  const windows = new Set()
  try {
    const out = execSync("tmux list-sessions -F '#{session_name}' 2>/dev/null", { encoding: "utf8" })
    for (const sess of out.trim().split("\n").filter(Boolean)) {
      try {
        const wins = execSync(`tmux list-windows -t '${sess}' -F '#{window_name}' 2>/dev/null`, { encoding: "utf8" })
        for (const w of wins.trim().split("\n").filter(Boolean)) {
          windows.add(`${sess}:${w}`)
        }
      } catch {}
    }
  } catch {}
  return windows
}

function checkOpencodeSession(sessionId) {
  try {
    const out = execSync(`curl -sS --max-time 2 http://127.0.0.1:4096/session/${sessionId}`, { encoding: "utf8" })
    const data = JSON.parse(out)
    return data && !data.error
  } catch {
    return false
  }
}

function getActiveJob(agentName) {
  try {
    const jobs = JSON.parse(readFileSync(path.join(STATE_ROOT, "jobs.json"), "utf8"))
    const all = jobs.jobs ? Object.values(jobs.jobs) : Object.values(jobs)
    return all.find(j => j.agent === agentName && (j.status === "running" || j.status === "dispatched"))
  } catch {
    return null
  }
}

function buildTasksEmbed() {
  let activeTasks = [], openBlockers = [], pendingApprovals = []
  try {
    const tasks = JSON.parse(readFileSync(path.join(STATE_ROOT, "tasks.json"), "utf8"))
    const all = tasks.tasks ? Object.values(tasks.tasks) : Object.values(tasks)
    activeTasks = all.filter(t => t.status !== "completed" && t.status !== "archived").slice(0, 15)
  } catch {}
  try {
    const blockers = JSON.parse(readFileSync(path.join(STATE_ROOT, "blockers.json"), "utf8"))
    const all = blockers.blockers ? Object.values(blockers.blockers) : Object.values(blockers)
    openBlockers = all.filter(b => b.status === "open").slice(0, 10)
  } catch {}
  try {
    const approvals = JSON.parse(readFileSync(path.join(STATE_ROOT, "approvals.json"), "utf8"))
    const all = approvals.approvals ? Object.values(approvals.approvals) : Object.values(approvals)
    pendingApprovals = all.filter(a => a.status === "pending").slice(0, 10)
  } catch {}

  const embed = new EmbedBuilder()
    .setTitle("OpenFleet — Tasks & Blockers")
    .setColor(openBlockers.length > 0 ? 0xED4245 : pendingApprovals.length > 0 ? 0xFEE75C : 0x57F287)
    .setDescription(`Updated <t:${Math.floor(Date.now() / 1000)}:R>`)

  // Active tasks
  if (activeTasks.length > 0) {
    const statusIcon = { created: "⬜", "in-progress": "🔵", blocked: "🔴", "in_progress": "🔵" }
    const lines = activeTasks.map(t => {
      const icon = statusIcon[t.status] || "⬜"
      const assignee = t.assignee ? ` → ${t.assignee}` : ""
      return `${icon} ${t.title?.slice(0, 60) || "untitled"}${assignee}`
    })
    embed.addFields({ name: `Active Tasks (${activeTasks.length})`, value: lines.join("\n").slice(0, 1024), inline: false })
  } else {
    embed.addFields({ name: "Tasks", value: "None active", inline: false })
  }

  // Blockers
  if (openBlockers.length > 0) {
    const lines = openBlockers.map(b => `🔴 **${b.agent_id || "?"}**: ${(b.summary || b.question || "").slice(0, 80)}`)
    embed.addFields({ name: `Open Blockers (${openBlockers.length})`, value: lines.join("\n").slice(0, 1024), inline: false })
  }

  // Approvals
  if (pendingApprovals.length > 0) {
    const lines = pendingApprovals.map(a => `🟡 **${a.agent_id || "?"}**: ${(a.summary || "").slice(0, 80)}`)
    embed.addFields({ name: `Pending Approvals (${pendingApprovals.length})`, value: lines.join("\n").slice(0, 1024), inline: false })
  }

  if (openBlockers.length === 0 && pendingApprovals.length === 0) {
    embed.addFields({ name: "Flow", value: "No blockers or approvals", inline: false })
  }

  embed.setFooter({ text: "Auto-updates every 60s" })
  embed.setTimestamp()
  return embed
}

const TASKS_CHANNEL = config.channels?.["tasks"]

async function updateTasksBoard() {
  if (!TASKS_CHANNEL) return
  const embed = buildTasksEmbed()
  const board = loadStatusBoard()
  const key = "tasksMessageId"

  try {
    if (board[key]) {
      const ch = await client.channels.fetch(TASKS_CHANNEL)
      const msg = await ch.messages.fetch(board[key])
      await msg.edit({ embeds: [embed] })
    } else {
      const ch = await client.channels.fetch(TASKS_CHANNEL)
      const msg = await ch.send({ embeds: [embed] })
      board[key] = msg.id
      saveStatusBoard(board)
    }
  } catch (err) {
    if (err.code === 10008) {
      try {
        const ch = await client.channels.fetch(TASKS_CHANNEL)
        const msg = await ch.send({ embeds: [embed] })
        board[key] = msg.id
        saveStatusBoard(board)
      } catch {}
    }
  }
}

async function updateStatusBoard() {
  if (!STATUS_CHANNEL) return
  const embed = buildStatusEmbed()
  const board = loadStatusBoard()

  try {
    if (board.messageId) {
      // Edit existing message
      const ch = await client.channels.fetch(STATUS_CHANNEL)
      const msg = await ch.messages.fetch(board.messageId)
      await msg.edit({ embeds: [embed] })
    } else {
      // Create new message and save ID
      const ch = await client.channels.fetch(STATUS_CHANNEL)
      const msg = await ch.send({ embeds: [embed] })
      board.messageId = msg.id
      board.channelId = STATUS_CHANNEL
      saveStatusBoard(board)
      process.stderr.write(`openfleet-gateway: status board created (${msg.id})\n`)
    }
  } catch (err) {
    // Message might have been deleted — create a new one
    if (err.code === 10008) { // Unknown Message
      try {
        const ch = await client.channels.fetch(STATUS_CHANNEL)
        const msg = await ch.send({ embeds: [embed] })
        board.messageId = msg.id
        board.channelId = STATUS_CHANNEL
        saveStatusBoard(board)
        process.stderr.write(`openfleet-gateway: status board recreated (${msg.id})\n`)
      } catch (e2) {
        process.stderr.write(`openfleet-gateway: status board failed: ${e2.message}\n`)
      }
    } else {
      process.stderr.write(`openfleet-gateway: status board update failed: ${err.message}\n`)
    }
  }
}

// ---- Startup ---------------------------------------------------------------

async function start() {
  await mcp.connect(new StdioServerTransport())
  process.stderr.write("openfleet-gateway: MCP server connected\n")

  httpServer.listen(HTTP_PORT, "127.0.0.1", () => {
    process.stderr.write(`openfleet-gateway: HTTP side-channel on 127.0.0.1:${HTTP_PORT}\n`)
  })

  client.once("ready", (c) => {
    process.stderr.write(`openfleet-gateway: Discord connected as ${c.user.tag}\n`)
    process.stderr.write(`openfleet-gateway: guilds: ${c.guilds.cache.map(g => `${g.name}(${g.id})`).join(", ")}\n`)
    process.stderr.write(`openfleet-gateway: channels monitored: ${Object.keys(channelIdToName).length}\n`)
    setInterval(() => { pollPermissions().catch(() => {}) }, POLL_INTERVAL)
    process.stderr.write("openfleet-gateway: permission watcher started (3s)\n")
    // Status boards — update immediately then every 60s
    updateStatusBoard().catch(() => {})
    updateTasksBoard().catch(() => {})
    setInterval(() => {
      updateStatusBoard().catch(() => {})
      updateTasksBoard().catch(() => {})
    }, STATUS_INTERVAL)
    process.stderr.write("openfleet-gateway: status boards started (60s)\n")
  })

  await client.login(TOKEN)
}

// ---- Graceful shutdown -----------------------------------------------------

let shuttingDown = false
function shutdown() {
  if (shuttingDown) return
  shuttingDown = true
  process.stderr.write("openfleet-gateway: shutting down\n")
  httpServer.close()
  setTimeout(() => process.exit(0), 2000)
  client.destroy().finally(() => process.exit(0))
}

process.stdin.on("end", shutdown)
process.stdin.on("close", shutdown)
process.on("SIGTERM", shutdown)
process.on("SIGINT", shutdown)

start().catch((err) => {
  process.stderr.write(`openfleet-gateway: startup failed: ${err}\n`)
  process.exit(1)
})
