#!/usr/bin/env node

const path = require('path')
const { execFileSync } = require('child_process')

function main() {
  const session = process.argv[2] || 'openfleet-ops'
  const opsBin = path.resolve(__dirname, 'ops')
  const agents = JSON.parse(execFileSync('node', [opsBin, 'dashboard'], { encoding: 'utf8' })).agents || []
  const alive = agents.filter((agent) => agent.runtime_state && agent.runtime_state !== 'dead')
  if (!alive.length) {
    throw new Error('No alive agents to follow')
  }

  recreateSession(session, alive)

  process.stdout.write(`${session}\n`)
}

function recreateSession(name, agents) {
  try {
    execFileSync('tmux', ['kill-session', '-t', name], { stdio: 'ignore' })
  } catch {
    // ignore
  }

  const [first, ...rest] = agents
  const opsBin = path.resolve(__dirname, 'ops')
  execFileSync('tmux', ['new-session', '-d', '-s', name, '-n', first.name, 'sh', '-lc', `node ${opsBin} follow ${first.name}`], { stdio: 'ignore' })
  for (const agent of rest) {
    execFileSync('tmux', ['new-window', '-t', name, '-n', agent.name, 'sh', '-lc', `node ${opsBin} follow ${agent.name}`], { stdio: 'ignore' })
  }
}

try {
  main()
} catch (error) {
  console.error(error.message)
  process.exit(1)
}
