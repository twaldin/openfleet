#!/usr/bin/env node
// openfleet post — remote-agnostic message posting for agents
// Resolves agent identity, emits agent.post event, bridge routes to configured remote.
const { execFileSync } = require("child_process")
const os = require("os")
const path = require("path")
const { createEventStore } = require("../core/runtime/events")
const { loadRemoteConfig, resolveEventRouting } = require("../core/remote/config")
const { createAdapter } = require("../core/remote/adapter")

const STATE_ROOT = process.env.OPENFLEET_CANONICAL_STATE_DIR || path.join(os.homedir(), ".openfleet")

function resolveAgentId() {
  // 1. Explicit env var
  if (process.env.OPENFLEET_AGENT_ID) return process.env.OPENFLEET_AGENT_ID

  // 2. Resolve from TMUX_PANE (identifies which pane the calling process is in)
  //    display-message without -t returns the ACTIVE window, not the caller's window
  if (process.env.TMUX_PANE) {
    try {
      const windowName = execFileSync("tmux", [
        "display-message", "-t", process.env.TMUX_PANE, "-p", "#{window_name}",
      ], { encoding: "utf8", stdio: ["pipe", "pipe", "ignore"] }).trim()
      if (windowName && windowName !== "bash" && windowName !== "zsh") return windowName
    } catch {}
  }

  // 3. Fallback: check parent process's tmux pane via /proc or ps
  try {
    const windowName = execFileSync("tmux", ["display-message", "-p", "#{window_name}"], {
      encoding: "utf8",
      stdio: ["pipe", "pipe", "ignore"],
    }).trim()
    if (windowName && windowName !== "bash" && windowName !== "zsh") return windowName
  } catch {}

  return "unknown"
}

function main() {
  const args = process.argv.slice(2)
  const message = args.filter(a => !a.startsWith("--")).join(" ")
  const agentIdx = args.indexOf("--agent")
  const channelIdx = args.indexOf("--channel")
  const agentId = (agentIdx !== -1 && agentIdx + 1 < args.length) ? args[agentIdx + 1] : resolveAgentId()
  const channelOverride = (channelIdx !== -1 && channelIdx + 1 < args.length) ? args[channelIdx + 1] : null

  if (!message) {
    console.error("Usage: openfleet post <message> [--agent <name>] [--channel <channel>]")
    process.exit(1)
  }

  // Try direct delivery first, mark event accordingly
  const config = loadRemoteConfig(STATE_ROOT)
  const provider = config?.provider
  let directDelivered = false

  if (provider) {
    const routing = resolveEventRouting(config, "agent.post")
    if (routing.post) {
      try {
        const adapter = createAdapter(provider, config[provider], STATE_ROOT)
        const channel = channelOverride || routing.channel
        const tempEvent = { type: "agent.post", agent_id: agentId, payload: { message } }
        const formatted = adapter.formatEvent(tempEvent)
        adapter.post(channel, formatted, { agent_id: agentId })
        adapter.destroy()
        directDelivered = true
      } catch (e) {
        console.error(`Warning: direct post failed (${e.message}), event saved for bridge pickup`)
      }
    }
  }

  // Emit event (bridge skips if already delivered directly)
  const events = createEventStore(STATE_ROOT)
  const event = events.append({
    type: "agent.post",
    agent_id: agentId,
    severity: "info",
    payload: { message, channel: channelOverride, _direct_delivered: directDelivered || undefined },
  })

  console.log(JSON.stringify({ ok: true, event_id: event.id, agent: agentId }))
}

try {
  main()
} catch (e) {
  console.error(e.message)
  process.exit(1)
}
