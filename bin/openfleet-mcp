#!/usr/bin/env node

const os = require('os')
const path = require('path')
const { handleRequest } = require('../core/mcp')

const stateRoot = process.env.OPENFLEET_CANONICAL_STATE_DIR || path.join(os.homedir(), '.openfleet')
let buffer = Buffer.alloc(0)

process.stdin.on('data', (chunk) => {
  buffer = Buffer.concat([buffer, chunk])
  drain()
})

function drain() {
  while (true) {
    const marker = buffer.indexOf('\r\n\r\n')
    if (marker === -1) return
    const header = buffer.slice(0, marker).toString('utf8')
    const match = header.match(/Content-Length: (\d+)/i)
    if (!match) throw new Error('Missing Content-Length header')
    const length = Number(match[1])
    const start = marker + 4
    const end = start + length
    if (buffer.length < end) return
    const payload = buffer.slice(start, end).toString('utf8')
    buffer = buffer.slice(end)
    handleMessage(JSON.parse(payload))
  }
}

function handleMessage(message) {
  if (!message.id) {
    if (message.method === 'notifications/initialized') return
    return
  }

  try {
    const result = handleRequest(stateRoot, message)
    write({ jsonrpc: '2.0', id: message.id, result })
  } catch (error) {
    write({ jsonrpc: '2.0', id: message.id, error: { code: -32000, message: error.message } })
  }
}

function write(message) {
  const body = Buffer.from(JSON.stringify(message), 'utf8')
  process.stdout.write(`Content-Length: ${body.length}\r\n\r\n`)
  process.stdout.write(body)
}
