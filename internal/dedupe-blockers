#!/usr/bin/env node

const os = require('os')
const path = require('path')
const { listBlockers, updateBlocker } = require('../core/runtime/blockers')
const { createEventStore } = require('../core/runtime/events')

function main() {
  const stateRoot = process.env.OPENFLEET_CANONICAL_STATE_DIR || path.join(os.homedir(), '.openfleet')
  const eventStore = createEventStore(stateRoot)
  const blockers = listBlockers(stateRoot).filter((b) => b.status === 'open')

  const groups = new Map()
  for (const blocker of blockers) {
    const key = [blocker.task_id || '', blocker.workflow_id || '', blocker.channel_binding || '', blocker.blocked_on_type || ''].join('|')
    if (!groups.has(key)) groups.set(key, [])
    groups.get(key).push(blocker)
  }

  const archived = []
  for (const items of groups.values()) {
    if (items.length <= 1) continue
    items.sort((a, b) => (a.updated_at < b.updated_at ? 1 : -1))
    const [keep, ...dupes] = items
    for (const dup of dupes) {
      const updated = updateBlocker(stateRoot, dup.id, { status: 'archived' })
      eventStore.append({ type: 'blocker.updated', agent_id: updated.agent_id || 'openfleet', payload: updated })
      archived.push({ kept: keep.id, archived: dup.id })
    }
  }

  process.stdout.write(`${JSON.stringify({ ok: true, archived }, null, 2)}\n`)
}

function normalize(value) {
  return String(value || '').toLowerCase().replace(/\s+/g, ' ').trim()
}

try {
  main()
} catch (error) {
  console.error(error.message)
  process.exit(1)
}
