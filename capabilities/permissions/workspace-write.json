{
  "name": "workspace-write",
  "type": "permissions",
  "description": "Allows agents to read and write within the current workspace.",
  "projections": {
    "claude-code": {
      "type": "json",
      "content": {
        "path": ".claude/permissions/workspace-write.json",
        "value": {
          "allow": [
            "workspace:read",
            "workspace:write"
          ]
        }
      }
    },
    "opencode": {
      "type": "json",
      "content": {
        "path": ".opencode/permissions/workspace-write.json",
        "value": {
          "allow": [
            "workspace:read",
            "workspace:write"
          ]
        }
      }
    }
  }
}
