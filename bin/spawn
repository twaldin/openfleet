#!/usr/bin/env node
// Universal agent spawner — works for any harness, with optional git worktree isolation
const { execFileSync } = require("child_process")
const fs = require("fs")
const os = require("os")
const path = require("path")
const { parseArgs } = require("../lib/opencode")
const {
  checkHealth,
  ensureOpenClawBinary,
  generateToken,
  sendMessage,
  shutdownOpenClaw,
} = require("../core/harness/openclaw")
const { loadDeploymentConfig } = require("../core/deployment")
const { projectInstructions } = require("../core/instructions")
const { loadRegistry, saveRegistry, upsertSession } = require("../core/runtime/registry")
const { createEventStore } = require("../core/runtime/events")
const {
  buildHarnessLaunchCommand,
  buildRemoteMkdirCommand,
  buildRemoteTmuxCaptureCommand,
  buildRemoteTmuxSendCommand,
  buildRemoteTmuxSpawnCommand,
  ensureRemoteHost,
  getHost,
  hostsFilePath,
  resolveRemoteWorkdir,
  rsyncDirectory,
  runSshCommand,
} = require("../core/remote/ssh")

async function main() {
  const args = parseArgs(process.argv.slice(2))
  const name = args._[0]
  const harness = args.harness || "claude-code"
  const model = args.model || "opus-4.6"
  let workdir = args.dir || process.env.OPENFLEET_WORKSPACE_ROOT || os.homedir()
  const tmuxSession = args["tmux-session"] || "openfleet"
  const stateRoot = args["state-root"] || process.env.OPENFLEET_CANONICAL_STATE_DIR || path.join(os.homedir(), ".openfleet")
  const hostsPath = hostsFilePath(stateRoot)
  const hostName = args.host || null
  const bootstrap = args.bootstrap || null
  const useWorktree = args.worktree || false
  const baseBranch = args["base-branch"] || "main"
  const deploymentPath = process.env.OPENFLEET_DEPLOYMENT || null

  if (!name) {
    console.error("Usage: spawn <name> --harness <claude-code|codex|opencode|openclaw> --model <model> [--dir <workdir>] [--worktree] [--host <hostname>] [--bootstrap <prompt>]")
    process.exit(1)
  }

  // Create git worktree for isolation if requested
  let worktreeInfo = null
  if (useWorktree) {
    worktreeInfo = createWorktree(workdir, name, baseBranch)
    workdir = worktreeInfo.path
  }

  if (deploymentPath) {
    try {
      const deployment = loadDeploymentConfig(deploymentPath)
      if (deployment) {
        projectInstructions(name, name, harness, workdir, deployment)
      }
    } catch {}
  }

  const openclawToken = harness === "openclaw" ? generateToken() : null
  if (!hostName && harness === "openclaw") {
    ensureOpenClawBinary()
  }

  const launch = buildHarnessLaunchCommand({ harness, model, workdir, name, token: openclawToken })
  let opencodePort = launch.opencodePort
  let openclawPort = launch.openclawPort
  let sessionWorkdir = workdir

  if (hostName) {
    const host = getHost(hostName, hostsPath)
    const remoteWorkdir = args["remote-dir"] || resolveRemoteWorkdir(name)

    await ensureRemoteHost({
      hostName,
      host,
      harness,
      hostsFile: hostsPath,
    })

    runSshCommand(host, buildRemoteMkdirCommand(remoteWorkdir), { timeout: 30000, stdio: "ignore" })
    rsyncDirectory(host, workdir, remoteWorkdir)

    const remoteLaunch = buildHarnessLaunchCommand({
      harness,
      model,
      workdir: remoteWorkdir,
      name,
      token: openclawToken,
    })
    opencodePort = remoteLaunch.opencodePort
    openclawPort = remoteLaunch.openclawPort
    sessionWorkdir = remoteWorkdir

    runSshCommand(host, buildRemoteTmuxSpawnCommand({
      tmuxSession,
      windowName: name,
      workdir: remoteWorkdir,
      launchCommand: remoteLaunch.command,
    }), { timeout: 30000, stdio: "ignore" })
  } else {
    // Ensure tmux session exists
    try {
      execFileSync("tmux", ["has-session", "-t", tmuxSession], { stdio: "ignore" })
    } catch {
      execFileSync("tmux", ["new-session", "-d", "-s", tmuxSession, "-n", "bootstrap"], { stdio: "ignore" })
    }

    // Kill existing window if any
    if (harness === "openclaw") {
      const existingSession = findSessionByName(loadRegistry(stateRoot), name)
      if (existingSession?.openclaw_port && existingSession?.openclaw_token) {
        try {
          await shutdownOpenClaw(existingSession.openclaw_port, existingSession.openclaw_token)
        } catch {}
      }
    }

    try {
      execFileSync("tmux", ["kill-window", "-t", `${tmuxSession}:${name}`], { stdio: "ignore" })
    } catch { /* fine */ }

    execFileSync("tmux", [
      "new-window", "-t", tmuxSession, "-n", name, "-c", workdir, launch.command,
    ], { stdio: "ignore", shell: true })
  }

  if (harness === "openclaw") {
    if (hostName) {
      await waitForRemoteOpenClawHealth(getHost(hostName, hostsPath), openclawPort)
    } else {
      await waitForOpenClawHealth(openclawPort)
    }
  } else {
    // Wait for CLI to initialize (opencode needs longer: serve start + attach)
    sleep(harness === "opencode" ? 8000 : 3000)
  }

  // Handle Codex trust prompt
  if (harness === "codex") {
    const pane = hostName
      ? runSshCommand(getHost(hostName, hostsPath), buildRemoteTmuxCaptureCommand({ tmuxSession, windowName: name }), { timeout: 5000 })
      : capturePane(tmuxSession, name)
    if (pane.includes("Do you trust")) {
      if (hostName) {
        runSshCommand(getHost(hostName, hostsPath), buildRemoteTmuxSendCommand({ tmuxSession, windowName: name, message: "1" }), {
          timeout: 15000,
          stdio: "ignore",
        })
      } else {
        execFileSync("tmux", ["send-keys", "-t", `${tmuxSession}:${name}`, "1", "Enter"], { stdio: "ignore" })
      }
      sleep(1500)
    }
  }

  // Send bootstrap prompt
  if (bootstrap) {
    if (!hostName && harness === "openclaw" && openclawPort && openclawToken) {
      await sendMessage(openclawPort, openclawToken, bootstrap)
    } else if (!hostName && harness === "opencode" && opencodePort) {
      // OpenCode: inject bootstrap via TUI API (append-prompt + submit-prompt)
      try {
        execFileSync("curl", [
          "-sS", "-X", "POST", `http://127.0.0.1:${opencodePort}/tui/append-prompt`,
          "-H", "Content-Type: application/json",
          "-d", JSON.stringify({ text: bootstrap }),
        ], { encoding: "utf8", timeout: 5000 })
        sleep(500)
        execFileSync("curl", [
          "-sS", "-X", "POST", `http://127.0.0.1:${opencodePort}/tui/submit-prompt`,
        ], { encoding: "utf8", timeout: 5000 })
      } catch (e) {
        console.error(`Warning: bootstrap via TUI API failed: ${e.message}`)
      }
    } else if (hostName) {
      if (harness === "openclaw" && openclawPort && openclawToken) {
        runSshCommand(getHost(hostName, hostsPath), buildRemoteOpenClawMessageCommand({
          port: openclawPort,
          token: openclawToken,
          message: bootstrap,
        }), { timeout: 30000, stdio: "ignore" })
      } else {
        runSshCommand(getHost(hostName, hostsPath), buildRemoteTmuxSendCommand({
          tmuxSession,
          windowName: name,
          message: bootstrap,
        }), { timeout: 30000, stdio: "ignore" })
      }
    } else {
      sendToPane(tmuxSession, name, bootstrap)
    }
  }

  // Register in openfleet registry
  const registry = loadRegistry(stateRoot)
  const sessionId = `spawn_${name}_${Date.now()}`
  upsertSession(registry, {
    session_id: sessionId,
    name,
    agent_id: name,
    runtime_instance_id: name,
    harness,
    model,
    tmux_session: tmuxSession,
    tmux_window: name,
    directory: sessionWorkdir,
    agentProfile: name,
    workspace: sessionWorkdir,
    worktree: worktreeInfo,
    opencode_port: opencodePort || null,
    openclaw_port: openclawPort || null,
    openclaw_token: openclawToken,
    host: hostName,
    transport: hostName ? "ssh" : null,
    created_at: Date.now(),
  })
  saveRegistry(stateRoot, registry)

  // Emit event
  createEventStore(stateRoot).append({
    type: "session.spawned",
    session_id: sessionId,
    agent_id: name,
    payload: {
      harness, model,
      tmux_session: tmuxSession, tmux_window: name,
      workdir: sessionWorkdir,
      worktree: worktreeInfo,
      host: hostName,
    },
  })

  const result = {
    ok: true,
    name,
    harness,
    model,
    session_id: sessionId,
    tmux_session: tmuxSession,
    tmux_window: name,
    workdir: sessionWorkdir,
    worktree: worktreeInfo,
    host: hostName,
  }
  console.log(JSON.stringify(result, null, 2))
}

function createWorktree(repoDir, name, baseBranch) {
  const branch = `openfleet/${name}`
  const worktreePath = path.join(os.tmpdir(), `openfleet-wt-${name}-${Date.now()}`)

  // Create branch from base
  try {
    execFileSync("git", ["-C", repoDir, "branch", "-D", branch], { stdio: "ignore" })
  } catch { /* branch didn't exist */ }

  execFileSync("git", ["-C", repoDir, "worktree", "add", "-b", branch, worktreePath, baseBranch], {
    stdio: "pipe", encoding: "utf8",
  })

  return { path: worktreePath, branch, base: baseBranch, repo: repoDir }
}

function sendToPane(session, window, message) {
  // Use load-buffer/paste-buffer for long messages, send-keys for short
  if (message.length > 500) {
    const tmp = path.join(os.tmpdir(), `openfleet-spawn-${Date.now()}.txt`)
    fs.writeFileSync(tmp, message)
    execFileSync("tmux", ["load-buffer", tmp], { stdio: "ignore" })
    execFileSync("tmux", ["paste-buffer", "-t", `${session}:${window}`], { stdio: "ignore" })
    fs.unlinkSync(tmp)
  } else {
    execFileSync("tmux", ["send-keys", "-t", `${session}:${window}`, "-l", message], { stdio: "ignore" })
  }
  execFileSync("tmux", ["send-keys", "-t", `${session}:${window}`, "Enter"], { stdio: "ignore" })
}

function capturePane(session, window) {
  return execFileSync("tmux", ["capture-pane", "-pt", `${session}:${window}`, "-S", "-40"], { encoding: "utf8" })
}

function findSessionByName(registry, name) {
  for (const session of Object.values(registry.sessions || {})) {
    if (session.name === name || session.agent_id === name) return session
  }
  return null
}

function buildRemoteOpenClawMessageCommand({ port, token, message }) {
  const payload = JSON.stringify({ message }).replace(/'/g, `'\\''`)
  return `curl --max-time 10 -fsS -X POST http://127.0.0.1:${port}/api/channels/openfleet/messages -H 'Authorization: Bearer ${token}' -H 'Content-Type: application/json' -d '${payload}'`
}

async function waitForOpenClawHealth(port, {
  timeoutMs = 30000,
  checkHealthImpl = checkHealth,
  sleepImpl = sleep,
} = {}) {
  const started = Date.now()
  while ((Date.now() - started) < timeoutMs) {
    if (await checkHealthImpl(port)) return true
    sleepImpl(500)
  }
  throw new Error(`Timed out waiting for OpenClaw health on port ${port}`)
}

async function waitForRemoteOpenClawHealth(host, port, {
  timeoutMs = 30000,
  runSshCommandImpl = runSshCommand,
  sleepImpl = sleep,
} = {}) {
  const started = Date.now()
  while ((Date.now() - started) < timeoutMs) {
    try {
      runSshCommandImpl(host, `curl --max-time 2 -fsS http://127.0.0.1:${port}/api/health`, {
        timeout: 5000,
        stdio: "ignore",
      })
      return true
    } catch {}
    sleepImpl(500)
  }
  throw new Error(`Timed out waiting for remote OpenClaw health on port ${port}`)
}

function sleep(ms) {
  Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, ms)
}

main().catch((e) => {
  console.error(e.message)
  process.exit(1)
})
